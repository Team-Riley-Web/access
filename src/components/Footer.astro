---
import { Image } from 'astro:assets';
import { Clock, Heart, Mail, MapPin, Phone } from '@lucide/astro';
import logo from '../assets/images/logo.png';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Team', href: '/team' },
  { label: 'Services', href: '/services' },
  { label: 'Results', href: '/transformations' },
  { label: 'Access Awareness', href: '/access-awareness' },
  { label: 'Contact', href: '/contact' },
];
---

<footer id="contact" class="bg-brand-900 text-white/80">
  <div class="mx-auto grid max-w-[calc(1280px+8rem)] gap-10 border-b border-white/10 px-5 py-16 sm:px-10 lg:grid-cols-[1.5fr_0.8fr_1fr_0.9fr] lg:gap-14 lg:px-20 lg:pb-14 lg:pt-20">
    <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
      <a href="/" aria-label="Access Aesthetics home">
        <Image
          src={logo}
          alt="Access Aesthetics"
          class="mb-5 h-auto w-40 brightness-0 invert"
          widths={[220, 320]}
        />
      </a>
      <p class="max-w-sm text-sm leading-[1.7] text-white/48">
        Medical aesthetics in Slidell, LA. Evidence-based treatments, expert care,
        and results that look like you, only refreshed.
      </p>
      <div class="mt-6 flex items-center justify-center gap-3 lg:justify-start">
        <a
          href="https://www.facebook.com/p/Access-Aesthetics-61569077104969/"
          target="_blank"
          rel="noreferrer"
          aria-label="Access Aesthetics on Facebook"
          class="inline-flex size-9 items-center justify-center rounded-full border border-white/12 text-white/42 transition hover:border-brand-300/50 hover:text-brand-300"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
          </svg>
        </a>
        <a
          href="https://www.instagram.com/accessaestheticsofla/"
          target="_blank"
          rel="noreferrer"
          aria-label="Access Aesthetics on Instagram"
          class="inline-flex size-9 items-center justify-center rounded-full border border-white/12 text-white/42 transition hover:border-brand-300/50 hover:text-brand-300"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
          </svg>
        </a>
        <a
          href="https://www.tiktok.com/@accessaestheticsofla"
          target="_blank"
          rel="noreferrer"
          aria-label="Access Aesthetics on TikTok"
          class="inline-flex size-9 items-center justify-center rounded-full border border-white/12 text-white/42 transition hover:border-brand-300/50 hover:text-brand-300"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z" />
          </svg>
        </a>
      </div>
    </div>

    <div class="hidden md:flex flex-col items-center text-center lg:items-start lg:text-left">
      <p class="mb-5 text-[0.64rem] font-semibold uppercase tracking-[0.22em] text-white/38">Menu</p>
      <div class="flex flex-col items-center gap-2.5 lg:items-start">
        {
          navItems.map((item) => (
            <a class="text-sm text-white/62 transition hover:text-white" href={item.href}>
              {item.label}
            </a>
          ))
        }
      </div>
    </div>

    <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
      <p class="mb-5 text-[0.64rem] font-semibold uppercase tracking-[0.22em] text-white/38">Contact</p>
      <div class="space-y-3.5 text-sm text-white/62">
        <p class="flex items-center justify-center gap-3 lg:justify-start">
          <MapPin class="size-4 shrink-0 text-brand-300" stroke-width={1.75} aria-hidden="true" />
          <span>1411 Lindberg Dr, Slidell, LA 70548</span>
        </p>
        <a class="flex items-center justify-center gap-3 transition hover:text-white lg:justify-start" href="tel:+19859605066">
          <Phone class="size-4 shrink-0 text-brand-300" stroke-width={1.75} aria-hidden="true" />
          <span>985-960-5066</span>
        </a>
        <a class="flex items-center justify-center gap-3 transition hover:text-white lg:justify-start" href="mailto:info@accessofla.com">
          <Mail class="size-4 shrink-0 text-brand-300" stroke-width={1.75} aria-hidden="true" />
          <span>info@accessofla.com</span>
        </a>
      </div>
    </div>

    <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
      <p class="mb-5 text-[0.64rem] font-semibold uppercase tracking-[0.22em] text-white/38">Hours</p>
      <div class="flex items-center gap-2">
        <Clock class="size-4 shrink-0 text-brand-300" stroke-width={1.75} aria-hidden="true" />
        <p class="whitespace-nowrap text-sm font-medium text-white/75">Mon – Fri <span class="font-normal text-white/45">9:00 AM – 5:00 PM</span></p>
      </div>
    </div>
  </div>

  <div class="mx-auto flex max-w-[calc(1280px+8rem)] flex-col items-center gap-2 px-5 py-6 sm:flex-row sm:items-center sm:justify-between sm:px-10 lg:px-20">
    <p class="text-[0.8rem] text-white/30">&copy; 2025 Access Aesthetics. All rights reserved.</p>
    <a
      href="https://teamrileyweb.com"
      target="_blank"
      rel="noreferrer"
      class="flex items-center gap-1.5 text-[0.8rem] text-white/30 transition hover:text-white"
    >
      Crafted with
      <Heart class="size-3.5 shrink-0 text-brand-300 fill-brand-300" stroke-width={1.75} aria-hidden="true" />
      by Team Riley
    </a>
  </div>
</footer>
