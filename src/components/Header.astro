---
import { Image } from 'astro:assets';
import { ChevronDown, Menu, X } from '@lucide/astro';
import logo from '../assets/images/logo.png';

const bookingUrl = 'https://www.myaestheticspro.com/';

const navItems = [
  { label: 'Home', href: '#home' },
  { label: 'About', href: '#about' },
  {
    label: 'Team',
    href: '#team',
    children: [
      { label: 'Amanda Clementi', href: '#team' },
      { label: 'Courtney Muller', href: '#team' },
      { label: 'Harley Lonardo', href: '#team' },
      { label: 'Melissa Holley', href: '#team' },
    ],
  },
  {
    label: 'Services',
    href: '#services',
    children: [
      { label: 'Neurotoxins', href: '#services' },
      { label: 'Morpheus 8 RF Microneedling', href: '#services' },
      { label: 'IPL (Intense Pulsed Light Therapy)', href: '#services' },
      { label: 'Laser Hair Removal', href: '#services' },
      { label: 'Fillers', href: '#services' },
      { label: 'Rejuvapen Microneedling', href: '#services' },
      { label: 'Biostimulators', href: '#services' },
      { label: 'Chemical Peels', href: '#services' },
      { label: 'Biofiller and PRP', href: '#services' },
      { label: 'Facials', href: '#services' },
      { label: 'Lash and Brow Services', href: '#services' },
      { label: 'Vitamin Injections', href: '#services' },
      { label: 'ZO Skincare', href: '#services' },
      { label: 'Epicutis Skincare', href: '#services' },
      { label: 'Revision Skincare', href: '#services' },
      { label: 'EltaMD Sunscreen', href: '#services' },
    ],
  },
  { label: 'Transformations', href: '#transformations' },
  { label: 'Access Awareness', href: '#contact' },
  {
    label: 'Contact',
    href: '#contact',
    children: [
      { label: 'Memberships', href: '#contact' },
      { label: 'Prepare For Your Appointment', href: '#contact' },
    ],
  },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 bg-white/94 backdrop-blur-xl transition-all duration-300"
  x-bind:class="scrolled ? 'h-14' : 'h-20'"
  x-data="{ open: false, scrolled: false }"
  x-init="
    scrolled = window.scrollY > 24;
    window.addEventListener('scroll', () => { scrolled = window.scrollY > 24 }, { passive: true });
  "
>
  <div class="mx-auto flex h-full max-w-[calc(1280px+8rem)] items-center justify-between px-5 sm:px-8 lg:px-16">
    <a href="#home" class="flex w-40 items-center sm:w-44" aria-label="Access Aesthetics home">
      <Image
        src={logo}
        alt="Access Aesthetics"
        class="h-auto transition-all duration-300"
        x-bind:class="scrolled ? 'w-28 sm:w-32' : 'w-40 sm:w-44'"
        widths={[180, 220, 320, 420]}
      />
    </a>

    <nav class="hidden items-center gap-5 xl:gap-7 lg:flex" aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <div class="group relative">
            <a
              href={item.href}
              class="inline-flex items-center gap-1.5 whitespace-nowrap font-logo text-[0.82rem] font-normal uppercase tracking-[0.12em] text-[#5a6070] transition hover:text-[#141820] xl:text-[0.92rem] xl:tracking-[0.14em]"
            >
              <span>{item.label}</span>
              {item.children && (
                <ChevronDown
                  class="size-3 text-[#8b929e]/65 transition group-hover:text-brand-600"
                  stroke-width={1.7}
                  aria-hidden="true"
                />
              )}
            </a>
            {item.children && (
              <div class="invisible absolute left-0 top-full z-50 w-80 pt-4 opacity-0 transition group-hover:visible group-hover:opacity-100">
                <div class="bg-white/96 p-3 shadow-[0_18px_45px_rgba(20,24,32,0.12),0_1px_4px_rgba(20,24,32,0.08)] ring-1 ring-[#edebe7] backdrop-blur-xl">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-3 py-2 font-logo text-[0.82rem] font-normal uppercase tracking-[0.12em] text-[#5a6070] transition hover:bg-brand-50 hover:text-[#141820]"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={bookingUrl}
        class="hidden whitespace-nowrap bg-brand-700 px-5 py-2.5 font-logo text-[0.82rem] font-normal uppercase tracking-[0.12em] text-white transition hover:bg-brand-800 hover:shadow-[0_6px_20px_rgba(0,85,143,0.28)] sm:inline-flex xl:px-6 xl:text-base xl:tracking-[0.14em]"
      >
        Book your consult
      </a>
      <button
        type="button"
        class="inline-flex size-11 items-center justify-center bg-brand-700 text-white lg:hidden"
        aria-label="Toggle menu"
        :aria-expanded="open.toString()"
        @click="open = !open"
      >
        <Menu class="size-5" x-show="!open" aria-hidden="true" />
        <X class="size-5" x-show="open" x-cloak aria-hidden="true" />
      </button>
    </div>
  </div>

  <div class="lg:hidden" x-show="open" x-cloak x-transition @click.outside="open = false">
    <nav class="mx-5 mb-5 bg-white p-3 shadow-soft" aria-label="Mobile navigation">
      {
        navItems.map((item) => (
          <div>
            <a
              href={item.href}
              class="flex items-center justify-between px-4 py-3 font-logo text-base font-normal uppercase tracking-[0.14em] text-[#5a6070] transition hover:bg-brand-50 hover:text-[#141820]"
              @click="open = false"
            >
              <span>{item.label}</span>
              {item.children && <ChevronDown class="size-3.5 text-[#8b929e]/65" stroke-width={1.7} aria-hidden="true" />}
            </a>
            {item.children && (
              <div class="pb-2 pl-7">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2 font-logo text-sm font-normal uppercase tracking-[0.12em] text-[#5a6070] transition hover:bg-brand-50 hover:text-[#141820]"
                    @click="open = false"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))
      }
      <a
        href={bookingUrl}
        class="mt-3 flex items-center justify-center bg-brand-700 px-5 py-3 font-logo text-base font-normal uppercase tracking-[0.14em] text-white"
      >
        Book your consult
      </a>
    </nav>
  </div>
</header>
