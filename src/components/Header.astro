---
import { Image } from 'astro:assets';
import { ChevronDown, Menu, Phone, X } from '@lucide/astro';
import GradientButton from './GradientButton.astro';
import logo from '../assets/images/logo.png';

const bookingUrl = 'https://www.myaestheticspro.com/BN/index.cfm?EBF1FD22984FA3B7A047FFA8B567BBDD';

const navItems = [
  { label: 'Home', href: '/' },
  {
    label: 'About',
    href: '/about',
    children: [
      { label: 'Team', href: '/about#meet-our-team' },
      { label: 'Amanda Clementi', href: '/about#amanda-clementi' },
      { label: 'Courtney Muller', href: '/about#courtney-miller' },
      { label: 'Harley Lonardo', href: '/about#harley-lonardo' },
      { label: 'Melissa Holley', href: '/about#melissa-holley' },
      { label: 'Access Awareness', href: '/about#access-awareness' },
    ],
  },
  {
    label: 'Services',
    href: '/services',
    children: [
      { label: 'Neurotoxins', href: '/services#neurotoxins' },
      { label: 'Morpheus8 Burst RF Microneedling', href: '/services#morpheus-8-microneedling' },
      { label: 'Lumecca IPL', href: '/services#intense-pulse-light-therapy' },
      { label: 'Plexr Plasma', href: '/services#plexr-plasma' },
      { label: 'Fractional CO2 Laser Resurfacing', href: '/services#fractional-co2-laser-resurfacing' },
      { label: 'Laser Hair Removal', href: '/services#laser-hair-removal' },
      { label: 'Fillers', href: '/services#fillers' },
      { label: 'Rejuvapen Microneedling', href: '/services#rejuvapen-microneedling' },
      { label: 'Biostimulators', href: '/services#biostimulators' },
      { label: 'Chemical Peels', href: '/services#chemical-peels' },
      { label: 'Biofiller and PRP', href: '/services#biofiller-and-prp' },
      { label: 'Facials', href: '/services#facials' },
      { label: 'Lash and Brow Services', href: '/services#lash-and-brow-services' },
      { label: 'Vitamin Injections', href: '/services#vitamin-injections' },
      { label: 'ZO Skincare', href: '/services#zo-skincare' },
      { label: 'Epicutis Skincare', href: '/services#epicutis-skincare' },
      { label: 'Revision Skincare', href: '/services#revision-skincare' },
      { label: 'EltaMD Sunscreen', href: '/services#elta-md-sunscreen' },
    ],
  },
  { label: 'Transformations', href: '/transformations' },
  { label: 'Contact', href: '/contact', children: [
    { label: 'Memberships', href: '/contact#memberships' },
    { label: 'Prepare For Your Appointment', href: '/contact#prepare-for-your-appointment' },
  ] },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 h-20 bg-white/94 shadow-[0_10px_30px_rgba(20,24,32,0.08),0_1px_0_rgba(98,196,243,0.22)] backdrop-blur-xl"
  x-data="{ open: false }"
>
  <div class="mx-auto flex h-full max-w-[calc(1280px+8rem)] items-center justify-between px-5 sm:px-8 lg:px-16">
    <a href="/" class="flex w-40 items-center sm:w-44" aria-label="Access Aesthetics home">
      <Image
        src={logo}
        alt="Access Aesthetics"
        class="h-auto w-40 sm:w-44"
        widths={[180, 220, 320, 420]}
      />
    </a>

    <nav
      class="ml-auto hidden items-center gap-4 transition-all duration-300 xl:flex 2xl:gap-5"
      aria-label="Primary navigation"
    >
      {
        navItems.map((item) => (
          <div class="group relative">
            <a
              href={item.href}
              class="inline-flex items-center gap-1.5 whitespace-nowrap text-[0.9rem] font-normal uppercase tracking-[0.13em] text-[#5a6070] transition-all duration-300 hover:text-[#141820] xl:text-[0.98rem] xl:tracking-[0.14em]"
            >
              <span>{item.label}</span>
              {item.children && (
                <ChevronDown
                  class="size-3 text-[#8b929e]/65 transition group-hover:text-brand-600"
                  stroke-width={1.7}
                  aria-hidden="true"
                />
              )}
            </a>
            {item.children && (
              <div class="invisible absolute left-0 top-full z-50 w-80 pt-4 opacity-0 transition group-hover:visible group-hover:opacity-100">
                <div class="bg-white/96 p-3 shadow-[0_18px_45px_rgba(20,24,32,0.12),0_1px_4px_rgba(20,24,32,0.08)] ring-1 ring-[#edebe7] backdrop-blur-xl">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-3 py-2 text-[0.82rem] font-normal uppercase tracking-[0.12em] text-[#5a6070] transition hover:bg-brand-50 hover:text-[#141820]"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))
      }
    </nav>

    <div class="ml-6 flex items-center gap-3 xl:ml-10">
      <GradientButton
        href={bookingUrl}
        class="hidden whitespace-nowrap px-5 py-2.5 text-[0.9rem] font-normal sm:inline-flex xl:px-6 xl:text-[0.98rem] xl:tracking-[0.14em]"
      >
        Book Now
      </GradientButton>
      <a
        href="tel:+19859605066"
        class="inline-flex size-11 items-center justify-center border border-brand-200 text-brand-700 transition hover:border-brand-400 hover:text-brand-500 xl:hidden"
        aria-label="Call us"
      >
        <Phone class="size-4" stroke-width={1.75} aria-hidden="true" />
      </a>
      <GradientButton
        type="button"
        class="size-11 xl:hidden"
        aria-label="Toggle menu"
        :aria-expanded="open.toString()"
        @click="open = !open"
      >
        <Menu class="size-5" x-show="!open" aria-hidden="true" />
        <X class="size-5" x-show="open" x-cloak aria-hidden="true" />
      </GradientButton>
    </div>
  </div>

  <div class="xl:hidden" x-show="open" x-cloak x-transition @click.outside="open = false">
    <nav class="border-t border-brand-100 bg-white shadow-[0_8px_24px_rgba(20,24,32,0.08)]" aria-label="Mobile navigation">
      {
        navItems.map((item) => (
          <div x-data={item.children ? "{ expanded: false }" : "{}"} class="border-b border-brand-50">
            {item.children ? (
              <div class="flex items-center">
                <a
                  href={item.href}
                  class="flex-1 px-5 py-3.5 font-logo text-base font-normal uppercase tracking-[0.14em] text-[#5a6070] transition hover:text-[#141820]"
                  @click="open = false"
                >
                  {item.label}
                </a>
                <button
                  type="button"
                  class="px-5 py-3.5 text-[#8b929e]/65 transition hover:text-brand-600"
                  @click="expanded = !expanded"
                  :aria-expanded="expanded.toString()"
                >
                  <ChevronDown class="size-4 transition duration-300" x-bind:class="expanded ? 'rotate-180' : ''" stroke-width={1.7} aria-hidden="true" />
                </button>
              </div>
            ) : (
              <a
                href={item.href}
                class="flex items-center px-5 py-3.5 font-logo text-base font-normal uppercase tracking-[0.14em] text-[#5a6070] transition hover:text-[#141820]"
                @click="open = false"
              >
                {item.label}
              </a>
            )}
            {item.children && (
              <div x-show="expanded" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-1" x-transition:enter-end="opacity-100 translate-y-0">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block bg-brand-50 px-5 py-2.5 font-logo text-sm font-normal uppercase tracking-[0.12em] text-[#5a6070] transition hover:bg-brand-100 hover:text-[#141820]"
                    @click="open = false"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))
      }
      <div class="px-5 py-4">
        <GradientButton
          href={bookingUrl}
          class="flex px-5 py-3 font-logo text-base font-normal"
        >
          Book your consult
        </GradientButton>
      </div>
    </nav>
  </div>
</header>
