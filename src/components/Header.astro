---
import { Image } from 'astro:assets';
import { Menu, X } from '@lucide/astro';
import logo from '../assets/images/logo.png';

const bookingUrl = 'https://www.myaestheticspro.com/';

const navItems = [
  { label: 'About', href: '#about' },
  { label: 'Treatments', href: '#services' },
  { label: 'Our Team', href: '#team' },
  { label: 'Results', href: '#transformations' },
  { label: 'Contact', href: '#contact' },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 h-20 bg-white/94 backdrop-blur-xl"
  x-data="{ open: false }"
>
  <div class="mx-auto flex h-full max-w-[calc(1280px+8rem)] items-center justify-between px-5 sm:px-8 lg:px-16">
    <a href="#home" class="inline-flex items-center" aria-label="Access Aesthetics home">
      <Image src={logo} alt="Access Aesthetics" class="h-auto w-40 sm:w-44" widths={[220, 320, 420]} />
    </a>

    <nav class="hidden items-center gap-9 lg:flex" aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <a href={item.href} class="text-sm text-[#5a6070] transition hover:text-[#141820]">
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={bookingUrl}
        class="hidden bg-brand-700 px-6 py-2.5 text-sm font-medium text-white transition hover:bg-brand-800 hover:shadow-[0_6px_20px_rgba(0,85,143,0.28)] sm:inline-flex"
      >
        Book your consult
      </a>
      <button
        type="button"
        class="inline-flex size-11 items-center justify-center bg-brand-700 text-white lg:hidden"
        aria-label="Toggle menu"
        :aria-expanded="open.toString()"
        @click="open = !open"
      >
        <Menu class="size-5" x-show="!open" aria-hidden="true" />
        <X class="size-5" x-show="open" x-cloak aria-hidden="true" />
      </button>
    </div>
  </div>

  <div class="lg:hidden" x-show="open" x-cloak x-transition @click.outside="open = false">
    <nav class="mx-5 mb-5 bg-white p-3 shadow-soft" aria-label="Mobile navigation">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="block px-4 py-3 text-sm font-medium text-[#5a6070] transition hover:bg-brand-50 hover:text-[#141820]"
            @click="open = false"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={bookingUrl}
        class="mt-3 flex items-center justify-center bg-brand-700 px-5 py-3 text-sm font-medium text-white"
      >
        Book your consult
      </a>
    </nav>
  </div>
</header>
