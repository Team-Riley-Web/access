---
interface Props {
  href?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  [key: string]: unknown;
}

const { href, class: className, type = 'button', ...attrs } = Astro.props as Props;

const classes = [
  'brand-cut-button inline-flex items-center justify-center gap-2 text-white',
  className,
];
---

{
  href ? (
    <a href={href} {...attrs} class:list={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} {...attrs} class:list={classes}>
      <slot />
    </button>
  )
}
