---
import { Image } from 'astro:assets';
import { ArrowRight, Check, Mail, X } from '@lucide/astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import PreFooterCTA from '../components/PreFooterCTA.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import aboutHeroImage from '../assets/images/services/smile.jpg';
import teamImage from '../assets/images/team.jpg';
import { aboutAddenda, bookingUrl, teamMembers } from '../data/site';

const title = 'About Access Aesthetics | Access Aesthetics';
const description = 'A refined, welcoming medical spa where advanced aesthetic treatments are guided by personalized care.';

const introCopy = [
  'Access Aesthetics exists to elevate natural beauty with cutting-edge treatments delivered in a refined and comfortable environment. The team focuses on personal care, thoughtful education, and results that help clients feel confident at every step.',
  'As an InMode Center of Excellence, Access brings advanced treatment technology together with a team that values listening first. Every plan is shaped around individual goals because beauty is never one-size-fits-all.',
];

const highlights = ['Exceptional team of experts', 'Advanced treatment technology', 'Personalized plans', 'Welcoming, judgment-free care'];

const awareness = aboutAddenda[0];
---

<BaseLayout title={title} description={description}>
  <Header />
  <main
    class="bg-[#f9f8f6] pt-20 text-[#141820]"
    x-data="{ selected: null }"
    x-init="
      const h = window.location.hash.slice(1);
      if (h && document.querySelector(`[data-modal-slug='${h}']`)) selected = h;
    "
  >
    <PageHero
      image={aboutHeroImage}
      imageAlt="A smiling Access Aesthetics client"
      kicker="Our Mission · Slidell, LA"
      title="About Access"
      description={description}
      flushBottom
    >
      <Fragment slot="actions">
        <a href={bookingUrl} class="brand-cut-button inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[0.875rem] font-medium text-white transition hover:-translate-y-px">
          Book your experience
          <ArrowRight class="size-3.5" aria-hidden="true" />
        </a>
        <a href="/services" class="inline-flex items-center justify-center gap-2 border-b border-[#e4e0db] pb-1 text-[0.9375rem] text-[#141820] transition hover:border-brand-400 hover:text-brand-700">
          Explore treatments
          <ArrowRight class="size-3.5" aria-hidden="true" />
        </a>
      </Fragment>
    </PageHero>

    <section class="relative overflow-hidden bg-[#3a477b] px-5 py-20 sm:px-10 lg:px-20 lg:py-28">
      <div class="absolute -right-28 top-16 h-80 w-80 rounded-full bg-brand-500/18 blur-3xl"></div>
      <div class="absolute bottom-0 left-10 h-72 w-72 rounded-full bg-brand-300/10 blur-3xl"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-white/5 via-transparent to-[#07121b]/48"></div>

      <div class="relative mx-auto max-w-7xl">
        <div data-reveal class="mx-auto mb-14 max-w-3xl text-left sm:text-center">
          <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-300">Who We Are</p>
          <h2 class="font-display text-[clamp(2.125rem,3.2vw,3.375rem)] font-medium leading-[1.1] tracking-[-0.01em] text-white">
            Expert care should still feel personal.
          </h2>
          <span class="mt-5 block h-[1px] w-32 rounded-full bg-[linear-gradient(90deg,rgba(110,193,213,0),#6ec1d5_50%,rgba(110,193,213,0))] opacity-85 sm:mx-auto"></span>
          <div class="mt-5 space-y-4 text-[1.0625rem] leading-[1.75] text-[#d6e3ea]">
            {introCopy.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>

        <div data-reveal data-reveal-delay="180" class="relative">
          <div class="overflow-hidden rounded-2xl shadow-[0_32px_95px_rgba(5,17,28,0.34),0_3px_10px_rgba(5,17,28,0.16)]">
            <Image
              src={teamImage}
              alt="The Access Aesthetics team in the Slidell studio"
              class="h-[320px] w-full object-cover object-top sm:h-[420px] lg:h-[500px]"
              widths={[720, 960, 1280, 1600]}
              sizes="(min-width: 1024px) 80vw, 100vw"
            />
          </div>
        </div>

        <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {highlights.map((item) => (
            <div class="flex items-center justify-center gap-3 bg-white/10 px-5 py-4 text-center shadow-[0_18px_50px_rgba(5,17,28,0.18),0_1px_4px_rgba(5,17,28,0.1)] backdrop-blur">
              <Check class="size-4 shrink-0 text-brand-300" stroke-width={2.5} aria-hidden="true" />
              <span class="text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-white/88">{item}</span>
            </div>
          ))}
        </div>

        <div class="mt-8 flex justify-center">
          <a
            href="#meet-our-team"
            class="brand-cut-button inline-flex items-center gap-2 px-7 py-3.5 text-[0.9375rem] font-medium text-white transition hover:-translate-y-px"
          >
            Meet the team
            <ArrowRight class="size-3.5" aria-hidden="true" />
          </a>
        </div>
      </div>
    </section>

    <section id={awareness.slug} class="overflow-hidden bg-[#0f1d29]">
      <div class="grid lg:grid-cols-2">
        <div class="relative min-h-[360px] overflow-hidden lg:min-h-[620px]">
          <Image
            src={awareness.image}
            alt={awareness.imageAlt}
            class="absolute inset-0 h-full w-full object-cover object-[center_25%]"
            widths={[720, 960, 1280]}
            sizes="(min-width: 1024px) 50vw, 100vw"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0f1d29]/78 via-transparent to-[#0f1d29]/10 lg:bg-gradient-to-l lg:from-[#0f1d29]/72 lg:via-transparent lg:to-[#0f1d29]/8"></div>
        </div>

        <div class="relative flex w-full items-center overflow-hidden px-6 py-16 sm:px-10 lg:px-16 lg:py-28">
          <div class="absolute -right-24 top-20 h-72 w-72 rounded-full bg-brand-500/18 blur-3xl"></div>
          <div class="absolute bottom-0 left-12 h-56 w-56 rounded-full bg-brand-300/10 blur-3xl"></div>
          <div data-reveal class="relative mx-auto max-w-2xl">
            <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-300">{awareness.kicker}</p>
            <h2 class="font-display text-[clamp(2.125rem,3.2vw,3.375rem)] font-normal leading-[1.1] tracking-[-0.01em] text-white">
              {awareness.title}
            </h2>
            <p class="mt-6 text-lg leading-[1.75] text-[#d6e3ea]">
              {awareness.summary}
            </p>
            <div class="mt-4 space-y-4 text-[0.95rem] leading-[1.75] text-[#b9cbd5]">
              {awareness.copy.map((paragraph) => <p>{paragraph}</p>)}
            </div>
            <div class="mt-8 grid gap-x-8 gap-y-3 sm:grid-cols-2">
              {awareness.highlights.map((item) => (
                <div class="flex items-center gap-3 border-b border-white/14 py-2.5">
                  <Check class="size-4 shrink-0 text-brand-300" stroke-width={2.5} aria-hidden="true" />
                  <span class="text-[0.76rem] font-semibold uppercase tracking-[0.1em] text-white/88">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="meet-our-team" class="px-5 py-16 sm:px-8 lg:px-16 lg:py-28">
      <div class="mx-auto max-w-7xl">
        <div data-reveal class="mb-14 max-w-2xl">
          <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">Behind The Glow</p>
          <h2 class="font-display text-[clamp(2rem,3vw,3rem)] font-normal leading-[1.12] tracking-[-0.01em] text-ink text-balance">
            The people behind the treatments.
          </h2>
          <p class="mt-5 text-[1.0625rem] leading-[1.75] text-[#5a6070]">
            The Access Aesthetics team brings together clinical skill and a passion for individualized care. Each provider helps create a welcoming environment where confidence, self-care, and wellness stay at the center of every visit.
          </p>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {teamMembers.map((member) => (
            <button
              type="button"
              x-on:click={`selected = '${member.slug}'`}
              class="group flex flex-col overflow-hidden bg-white text-left shadow-[0_18px_48px_rgba(20,24,32,0.08),0_1px_4px_rgba(20,24,32,0.04)] transition hover:-translate-y-1 hover:shadow-soft"
            >
              <div class="overflow-hidden">
                <Image
                  src={member.image}
                  alt={member.imageAlt}
                  class="aspect-[4/5] w-full object-cover object-top transition duration-500 group-hover:scale-[1.04]"
                  widths={[360, 520, 720]}
                  sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
                />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display text-2xl leading-tight text-ink">{member.name}</h3>
                <p class="mt-2 text-[0.64rem] font-semibold uppercase tracking-[0.16em] text-brand-600">{member.title}</p>
                <p class="mt-4 flex-1 text-sm leading-[1.7] text-[#5a6070]">{member.summary}</p>
                <span class="mt-6 inline-flex items-center gap-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-brand-700 underline decoration-brand-300 decoration-2 underline-offset-4">
                  Meet {member.name.split(' ')[0]}
                  <ArrowRight class="size-3.5 transition group-hover:translate-x-1" aria-hidden="true" />
                </span>
              </div>
            </button>
          ))}
        </div>
      </div>
    </section>

    <PreFooterCTA
      eyebrow="Come meet the team"
      titleLines={['Experience Care', 'Built Around You']}
      copy="Book a consultation and let a provider build a plan around your goals, your comfort level, and your timeline."
      href={bookingUrl}
      cta="Book your experience"
      showArrow
    />

    <div x-show="selected !== null" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-6">
      <div
        x-show="selected !== null"
        x-transition.opacity
        x-on:click="selected = null"
        class="absolute inset-0 bg-black/50"
      >
      </div>

      {teamMembers.map((member) => (
        <div
          data-modal-slug={member.slug}
          x-show={`selected === '${member.slug}'`}
          x-cloak
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 scale-95"
          x-transition:enter-end="opacity-100 scale-100"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 scale-100"
          x-transition:leave-end="opacity-0 scale-95"
          class="relative max-h-[85vh] w-full max-w-2xl overflow-y-auto bg-white p-7 shadow-lift sm:p-10"
        >
          <button
            type="button"
            x-on:click="selected = null"
            class="absolute right-5 top-5 flex size-9 items-center justify-center rounded-full bg-[#f9f8f6] text-[#5a6070] transition hover:bg-[#eceae7]"
            aria-label="Close"
          >
            <X class="size-4" aria-hidden="true" />
          </button>

          <div class="flex items-center gap-5">
            <Image src={member.image} alt={member.imageAlt} class="size-20 shrink-0 rounded-full object-cover" widths={[120, 160]} sizes="80px" />
            <div>
              <h2 class="font-display text-2xl leading-tight text-ink">{member.name}</h2>
              <p class="mt-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-brand-600">{member.title}</p>
            </div>
          </div>
          <div class="mt-6 space-y-4 text-[0.9375rem] leading-[1.75] text-[#5a6070]">
            {member.copy.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
          <div class="mt-7 flex flex-wrap gap-4">
            <a
              href={`mailto:${member.email}`}
              class="inline-flex items-center gap-2 border border-brand-200 px-6 py-3 text-[0.8rem] font-semibold uppercase tracking-[0.1em] text-brand-700 transition hover:border-brand-400"
            >
              <Mail class="size-4" aria-hidden="true" />
              Email {member.name.split(' ')[0]}
            </a>
            <a
              href={bookingUrl}
              class="brand-cut-button inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[0.875rem] font-medium text-white transition hover:-translate-y-px"
            >
              Book Now
              <ArrowRight class="size-3.5" aria-hidden="true" />
            </a>
          </div>
        </div>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
