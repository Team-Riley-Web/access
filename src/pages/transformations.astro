---
import { Image } from 'astro:assets';
import { ArrowRight, Check, Sparkles } from '@lucide/astro';
import Footer from '../components/Footer.astro';
import GradientButton from '../components/GradientButton.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import PreFooterCTA from '../components/PreFooterCTA.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import transformationsHeroImage from '../assets/images/services/mirror.jpg';
import { bookingUrl, transformations } from '../data/site';

const title = 'Transformations | Access Aesthetics';
const description = 'Visible change guided by thoughtful aesthetic treatment plans.';
const introCopy = [
  'Before-and-after photos are only part of the story. The real work is understanding what a client wants to see in the mirror, what timeline feels realistic, and which treatments can get them there without overdoing it.',
  'Every result shown here began with a personalized plan. Some transformations are subtle and progressive; others are more visible quickly. The goal is always the same: refreshed, confident, natural-looking change.',
];

const storyTransformation = transformations[1];

const storyPoints = [
  'Started with a focused consultation around skin texture, laxity, and profile goals',
  'Built a realistic treatment path instead of chasing a one-visit fix',
  'Tracked visible progress so the final result still felt natural and personal',
];
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="bg-[#f9f8f6] pt-20 text-[#141820]">
    <PageHero
      image={transformationsHeroImage}
      imageAlt="Aesthetic laser treatment in progress at Access Aesthetics"
      imagePosition="object-[center_42%]"
      kicker="Before and After"
      title="Transformations"
      description={description}
      flushBottom
    >
      <Fragment slot="actions">
        <GradientButton href={bookingUrl} class="px-7 py-3.5 text-[0.875rem] font-medium">
          Book Your Experience
          <ArrowRight class="size-3.5" aria-hidden="true" />
        </GradientButton>
        <a href="/services" class="inline-flex items-center justify-center gap-2 border-b border-[#e4e0db] pb-1 text-[0.9375rem] text-[#141820] transition hover:border-brand-400 hover:text-brand-700">
          Explore Services
        </a>
      </Fragment>
    </PageHero>

    <section class="relative overflow-hidden bg-[#07121b] px-5 py-16 sm:px-8 lg:px-16 lg:py-24">
      <div class="pointer-events-none absolute -left-24 top-12 h-80 w-80 rounded-full border border-white/12"></div>
      <div class="pointer-events-none absolute right-[-7rem] top-20 h-96 w-96 rounded-full border border-brand-300/18"></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_12%,rgba(59,130,180,0.22),transparent_34%),linear-gradient(135deg,rgba(4,86,142,0.28),transparent_48%)]"></div>
      <div class="relative mx-auto max-w-7xl">
        <div data-reveal class="mx-auto max-w-3xl text-center">
          <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-300">Real Results</p>
          <h2 class="font-display text-[clamp(2.25rem,4vw,4.25rem)] font-normal leading-[1.05] tracking-[-0.01em] text-white text-balance">
            The proof is in the progress.
          </h2>
          <div class="mx-auto mt-6 max-w-[66ch] space-y-5 text-[1.0625rem] leading-[1.78] text-[#d6e3ea]">
            {introCopy.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>

        <div class="mt-12 grid gap-4 sm:grid-cols-3 lg:mt-16">
          {[
            ['Personalized plan', 'Treatment decisions are guided by your goals, anatomy, and comfort level.'],
            ['Natural-looking change', 'The focus is visible improvement that still looks like you.'],
            ['Guided follow-through', 'Your provider helps you understand timing, maintenance, and next steps.'],
          ].map(([stat, copy]) => (
            <article class="bg-white/[0.07] p-6 text-center shadow-[0_22px_62px_rgba(0,0,0,0.24),0_1px_5px_rgba(0,0,0,0.16)] ring-1 ring-white/10 backdrop-blur-sm">
              <Sparkles class="mx-auto mb-5 size-5 text-brand-300" aria-hidden="true" />
              <h3 class="font-display text-2xl leading-tight text-white">{stat}</h3>
              <p class="mt-3 text-[0.92rem] leading-[1.65] text-white/68">{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#fbfaf8] px-5 py-16 sm:px-8 lg:px-16 lg:py-28">
      <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16">
        <div data-reveal class="relative">
          <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">Client Story</p>
          <h2 class="font-display text-[clamp(2.125rem,3.5vw,3.75rem)] font-normal leading-[1.08] tracking-[-0.01em] text-ink text-balance">
            From “I just look tired” to visibly renewed.
          </h2>
          <p class="mt-6 text-[1.0625rem] leading-[1.78] text-[#5a6070]">
            This client came in wanting a change that felt noticeable, but not obvious. The conversation started with what bothered them most day to day, then moved into a plan that respected their features, downtime, and comfort level.
          </p>
          <p class="mt-4 text-[1.0625rem] leading-[1.78] text-[#5a6070]">
            The final result is the kind of transformation Access aims for: refreshed, balanced, and confidence-building without losing the person underneath.
          </p>

          <div class="mt-8 grid gap-3">
            {storyPoints.map((point) => (
              <div class="flex items-start gap-3 bg-white p-4 shadow-[0_16px_42px_rgba(20,24,32,0.06),0_1px_4px_rgba(20,24,32,0.03)]">
                <Check class="mt-0.5 size-4 shrink-0 text-brand-600" stroke-width={2.5} aria-hidden="true" />
                <span class="text-[0.9rem] leading-[1.6] text-[#141820]">{point}</span>
              </div>
            ))}
          </div>

          <GradientButton
            href={bookingUrl}
            class="mt-9 px-7 py-3.5 text-[0.875rem] font-medium"
          >
            Start your plan
            <ArrowRight class="size-3.5" aria-hidden="true" />
          </GradientButton>
        </div>

        <figure data-reveal data-reveal-delay="140" class="bg-white p-3 shadow-[0_28px_80px_rgba(20,24,32,0.13),0_2px_8px_rgba(20,24,32,0.06)] ring-1 ring-[#e8e4de]">
          <Image
            src={storyTransformation.image}
            alt={storyTransformation.alt}
            class="aspect-[5/4] w-full object-cover"
            widths={[640, 960, 1280]}
            sizes="(min-width: 1024px) 48vw, 100vw"
          />
          <figcaption class="flex items-center justify-between gap-4 px-1.5 pb-1 pt-3.5 text-xs font-semibold uppercase tracking-[0.16em] text-[#8b929e]">
            <span>{storyTransformation.label}</span>
            <span>Featured Story</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="bg-[#07121b] px-5 py-16 sm:px-8 lg:px-16 lg:py-24">
      <div data-reveal class="mx-auto mb-12 max-w-3xl text-center">
        <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-300">Before & After Gallery</p>
        <h2 class="font-display text-[clamp(2rem,3vw,3.25rem)] font-normal leading-[1.1] tracking-[-0.01em] text-white">
          Results worth looking closer at.
        </h2>
        <p class="mx-auto mt-5 max-w-[58ch] text-[1.0625rem] leading-[1.75] text-[#d6e3ea]">
          Browse visible changes across skin, lips, brows, eyes, and contour-focused treatment plans.
        </p>
      </div>
      <div class="mx-auto grid max-w-7xl gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {transformations.map((item, index) => (
          <figure class="group bg-white/[0.07] p-3 shadow-[0_22px_70px_rgba(0,0,0,0.24),0_1px_5px_rgba(0,0,0,0.16)] ring-1 ring-white/10 transition hover:-translate-y-1 hover:bg-white/[0.1]">
            <Image src={item.image} alt={item.alt} class="aspect-square w-full object-cover" widths={[420, 640, 960]} sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw" />
            <figcaption class="flex items-center justify-between gap-4 px-1.5 pb-1 pt-3.5 text-xs font-semibold uppercase tracking-[0.16em] text-white/56">
              <span>{item.label}</span>
              <span>{String(index + 1).padStart(2, '0')} / {String(transformations.length).padStart(2, '0')}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class="bg-linear-to-b from-white via-brand-50/35 to-[#f9f8f6] px-5 py-16 sm:px-8 lg:px-16 lg:py-24">
      <div class="mx-auto grid max-w-7xl gap-4 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
        <div data-reveal>
          <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">What Happens Next</p>
          <h2 class="font-display text-[clamp(2.125rem,3.5vw,3.75rem)] font-normal leading-[1.08] tracking-[-0.01em] text-ink text-balance">
            Results start with a plan.
          </h2>
        </div>
        <div data-reveal data-reveal-delay="120" class="grid gap-4 sm:grid-cols-3">
          {[
            ['Consult', 'Talk through what you want to change, what you want to keep, and how natural you want the result to feel.'],
            ['Map', 'Your provider recommends the right sequence of services, timing, and maintenance so the plan feels clear.'],
            ['Refine', 'Progress is reviewed over time so changes can build intentionally instead of feeling rushed or overdone.'],
          ].map(([step, copy]) => (
            <article class="bg-white p-6 shadow-[0_18px_52px_rgba(20,24,32,0.08),0_1px_4px_rgba(20,24,32,0.04)]">
              <p class="text-[0.67rem] font-semibold uppercase tracking-[0.18em] text-brand-500">{step}</p>
              <p class="mt-4 text-[0.95rem] leading-[1.7] text-[#5a6070]">{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <PreFooterCTA
      eyebrow="Ready for your own before and after?"
      titleLines={['Start With', 'a Consultation']}
      copy="Bring your goals, questions, and timeline. The Access team will help you understand what is possible and build a treatment plan around you."
      href={bookingUrl}
      cta="Book your consult"
      showArrow
    />
  </main>
  <Footer />
</BaseLayout>
