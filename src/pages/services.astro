---
import servicesHeroImage from '../assets/images/services/eye.jpg';
import { ArrowRight, X } from '@lucide/astro';
import Footer from '../components/Footer.astro';
import GradientButton from '../components/GradientButton.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import PreFooterCTA from '../components/PreFooterCTA.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { bookingUrl, serviceCategories, serviceCategoryOrder, servicePages } from '../data/site';

const title = 'Our Services | Access Aesthetics';
const description = 'Aesthetic treatments for skin, structure, wellness, and everyday confidence.';

const categoryAnchors: Record<(typeof serviceCategoryOrder)[number], string> = {
  'Injectables & Fillers': 'injectables-fillers',
  'Skin Renewal & Resurfacing': 'skin-renewal',
  'Hair & Body': 'hair-body',
  Wellness: 'wellness',
  'Skincare Retail': 'skincare-retail',
};
---

<BaseLayout title={title} description={description}>
  <Header />
  <main
    class="bg-[#f9f8f6] pt-20 text-[#141820]"
    x-data="{ selected: null, activeCat: null }"
    x-init="
      const h = window.location.hash.slice(1);
      if (h && document.querySelector(`[data-modal-slug='${h}']`)) selected = h;
      const catSections = Array.from(document.querySelectorAll('[data-cat-section]'));
      if (catSections.length) {
        activeCat = catSections[0].id;
        const catObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => { if (entry.isIntersecting) activeCat = entry.target.id; });
        }, { rootMargin: '-35% 0px -55% 0px', threshold: 0 });
        catSections.forEach((section) => catObserver.observe(section));
      }
    "
  >
    <PageHero
      image={servicesHeroImage}
      imageAlt="A relaxing facial treatment at Access Aesthetics"
      imagePosition="object-[center_38%]"
      kicker="Treatments · Slidell, LA"
      title="Our Services"
      description={description}
      dark
    >
      <Fragment slot="actions">
        <a href={bookingUrl} class="inline-flex items-center gap-2 bg-white px-7 py-3.5 text-[0.875rem] font-medium text-brand-900 shadow-[0_18px_44px_rgba(0,0,0,0.22),0_1px_4px_rgba(0,0,0,0.16)] transition hover:bg-brand-50">
          Book your consult
          <ArrowRight class="size-3.5" aria-hidden="true" />
        </a>
        <a href={`#${categoryAnchors[serviceCategoryOrder[0]]}`} class="inline-flex items-center gap-1.5 border-b border-white/24 pb-1 text-[0.9375rem] text-white/82 transition hover:border-brand-300 hover:text-white">
          Browse by category
        </a>
      </Fragment>
    </PageHero>

    <section class="relative overflow-hidden bg-gradient-to-b from-white via-brand-50/35 to-[#f9f8f6] px-5 pb-12 pt-14 sm:px-8 sm:pt-16 lg:px-16 lg:pb-16 lg:pt-24">
      <div class="pointer-events-none absolute -left-24 top-8 h-72 w-72 rounded-full border border-brand-100/80"></div>
      <div class="pointer-events-none absolute right-[-6rem] top-20 h-96 w-96 rounded-full border border-brand-100/70"></div>
      <div class="relative mx-auto max-w-[calc(1280px+8rem)]">
        <div data-reveal class="mx-auto max-w-3xl text-center">
          <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">Treatment Menu</p>
          <h2 class="font-display text-[clamp(2rem,3.2vw,3.375rem)] font-normal leading-[1.1] tracking-[-0.01em] text-ink text-balance">
            Choose a category, then open any treatment for details.
          </h2>
          <p class="mx-auto mt-5 max-w-[58ch] text-[1.0625rem] leading-[1.75] text-[#5a6070]">
            Start with the area that matches your goals. Each service card opens into a concise treatment overview, and a consultation can help refine the right plan.
          </p>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-[calc(1280px+8rem)] px-5 pb-28 pt-4 sm:px-8 lg:px-16 lg:pt-10">
      <div class="sticky top-14 z-40 mb-10 w-screen -translate-x-5 overflow-hidden border-b border-[#e4e0db] bg-white/92 py-4 backdrop-blur-md md:-translate-x-8 lg:hidden">
        <div class="no-scrollbar overflow-x-auto overscroll-x-contain px-5 md:px-8">
          <ul class="flex snap-x snap-mandatory scroll-px-5 gap-6 whitespace-nowrap md:scroll-px-8">
            {serviceCategoryOrder.map((category) => (
              <li class="snap-start">
                <a
                  href={`#${categoryAnchors[category]}`}
                  x-bind:class={`activeCat === '${categoryAnchors[category]}' ? 'text-brand-700 font-semibold' : 'text-[#5a6070]'`}
                  class="inline-block py-1 text-[0.82rem] font-medium uppercase tracking-[0.08em] transition"
                >
                  {category}
                </a>
              </li>
            ))}
            <li class="w-5 shrink-0 md:w-8" aria-hidden="true"></li>
          </ul>
        </div>
      </div>

      <div class="grid gap-14 lg:grid-cols-[280px_1fr] lg:gap-20">
        <aside class="hidden lg:sticky lg:top-28 lg:block lg:self-start">
        <div class="bg-white/82 p-6 shadow-[0_22px_60px_rgba(20,24,32,0.08),0_1px_4px_rgba(20,24,32,0.04)] backdrop-blur">
        <p class="mb-5 text-[0.7rem] font-medium uppercase tracking-[0.22em] text-brand-500">Categories</p>
        <ul class="flex flex-col gap-1">
          {serviceCategoryOrder.map((category, idx) => (
            <li>
              <a
                href={`#${categoryAnchors[category]}`}
                class="flex items-baseline gap-3.5 px-3 py-3 text-sm transition"
                x-bind:class={`activeCat === '${categoryAnchors[category]}' ? 'bg-brand-50 text-brand-700 font-semibold' : 'text-[#5a6070] hover:bg-[#f9f8f6] hover:text-[#141820]'`}
              >
                <span
                  class="text-[0.72rem] font-medium tabular-nums transition"
                  x-bind:class={`activeCat === '${categoryAnchors[category]}' ? 'text-brand-600' : 'text-[#8b929e]'`}
                >
                  {String(idx + 1).padStart(2, '0')}
                </span>
                <span>{category}</span>
              </a>
            </li>
          ))}
        </ul>
        <a href={bookingUrl} class="mt-8 inline-flex w-full items-center justify-center gap-2 bg-ink px-5 py-3 text-center text-[0.78rem] font-semibold uppercase tracking-[0.12em] text-white shadow-[0_16px_36px_rgba(4,86,142,0.18),0_1px_4px_rgba(20,24,32,0.06)] transition hover:bg-brand-700">
          Book a consult
          <ArrowRight class="size-3.5" aria-hidden="true" />
        </a>
        </div>
        </aside>

        <div>
        {serviceCategoryOrder.map((category, idx) => {
          const services = servicePages.filter((service) => serviceCategories[service.slug] === category);
          const isRetail = category === 'Skincare Retail';
          return (
            <section id={categoryAnchors[category]} data-cat-section class="scroll-mt-40 lg:scroll-mt-32">
              {idx > 0 && <div class="mt-14 lg:mt-20" />}
              <div class="mb-9 flex flex-wrap items-baseline gap-4">
                <span class="font-display text-[0.85rem] font-medium text-brand-500">{String(idx + 1).padStart(2, '0')}</span>
                <h2 class="font-display text-[clamp(1.75rem,2.6vw,2.5rem)] leading-tight text-ink">{category}</h2>
                <span class="ml-auto whitespace-nowrap bg-white px-3 py-1.5 text-[0.8125rem] text-[#8b929e] shadow-[0_10px_28px_rgba(20,24,32,0.05)]">
                  {services.length} {isRetail ? (services.length === 1 ? 'product line' : 'product lines') : services.length === 1 ? 'treatment' : 'treatments'}
                </span>
              </div>

              <div class="grid gap-6 sm:grid-cols-2">
                {services.map((service) =>
                  isRetail ? (
                    <article class="bg-white/72 p-7 shadow-[0_18px_52px_rgba(4,86,142,0.08),0_1px_4px_rgba(20,24,32,0.04)] ring-1 ring-brand-100/70 transition hover:bg-white hover:ring-brand-300">
                      <p class="mb-2.5 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-brand-600">{service.kicker}</p>
                      <h3 class="font-display text-xl leading-snug text-ink">{service.title}</h3>
                      <p class="mt-2.5 text-[0.9rem] leading-[1.65] text-[#5a6070]">{service.summary}</p>
                    </article>
                  ) : (
                    <article
                      role="button"
                      tabindex="0"
                      x-on:click={`selected = '${service.slug}'`}
                      x-on:keydown.enter.prevent={`selected = '${service.slug}'`}
                      x-on:keydown.space.prevent={`selected = '${service.slug}'`}
                      class="group flex cursor-pointer flex-col bg-white/88 p-7 shadow-[0_18px_52px_rgba(20,24,32,0.08),0_1px_4px_rgba(20,24,32,0.04)] ring-1 ring-white/70 transition hover:-translate-y-1 hover:bg-brand-50/45 hover:shadow-[0_24px_70px_rgba(4,86,142,0.12),0_2px_7px_rgba(20,24,32,0.05)] hover:ring-brand-300 focus:outline-none focus:ring-2 focus:ring-brand-300 focus:ring-offset-4 focus:ring-offset-[#f9f8f6]"
                    >
                      <p class="mb-2.5 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-brand-600">{service.kicker}</p>
                      <h3 class="font-display text-xl leading-snug text-ink">{service.title}</h3>
                      <p class="mt-2.5 flex-1 text-[0.9rem] leading-[1.65] text-[#5a6070]">{service.summary}</p>
                      <div class="mt-5 flex items-center justify-between gap-4 border-t border-[#edebe7] pt-4">
                        <span class="inline-flex items-center gap-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-[#141820] underline decoration-brand-300 decoration-2 underline-offset-4 transition group-hover:text-brand-700">
                          Learn more
                          <ArrowRight class="size-3 transition group-hover:translate-x-0.5" aria-hidden="true" />
                        </span>
                        <a href={bookingUrl} x-on:click.stop class="text-[0.8rem] text-[#8b929e] transition hover:text-brand-600">Book &rarr;</a>
                      </div>
                    </article>
                  )
                )}
              </div>

              {isRetail && (
                <p class="mt-6 text-[0.8125rem] text-[#8b929e]">
                  Product lines are available in-studio &mdash; ask your provider for a personalized regimen at your next visit.
                </p>
              )}
            </section>
          );
        })}
        </div>
      </div>
    </div>

    <PreFooterCTA
      eyebrow="Find your treatment plan"
      titleLines={['Not Sure Where', 'to Start?']}
      copy="Start with a consultation. Your provider will build a plan around your skin, your timeline, and your comfort level."
      href={bookingUrl}
      cta="Book your consult"
      showArrow
    />

    <div x-show="selected !== null" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-6">
      <div
        x-show="selected !== null"
        x-transition.opacity
        x-on:click="selected = null"
        class="absolute inset-0 bg-black/50"
      >
      </div>

      {servicePages.map((service) => (
        <div
          data-modal-slug={service.slug}
          x-show={`selected === '${service.slug}'`}
          x-cloak
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 scale-95"
          x-transition:enter-end="opacity-100 scale-100"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 scale-100"
          x-transition:leave-end="opacity-0 scale-95"
          class="relative max-h-[85vh] w-full max-w-2xl overflow-y-auto bg-white p-7 shadow-lift sm:p-10"
        >
          <button
            type="button"
            x-on:click="selected = null"
            class="absolute right-5 top-5 flex size-9 items-center justify-center rounded-full bg-[#f9f8f6] text-[#5a6070] transition hover:bg-[#eceae7]"
            aria-label="Close"
          >
            <X class="size-4" aria-hidden="true" />
          </button>

          <p class="text-[0.64rem] font-semibold uppercase tracking-[0.2em] text-brand-500">{service.kicker}</p>
          <h2 class="mt-2 font-display text-3xl leading-tight text-ink">{service.title}</h2>
          <div class="mt-5 space-y-4 text-[0.9375rem] leading-[1.75] text-[#5a6070]">
            {service.copy.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
          <GradientButton
            href={bookingUrl}
            class="mt-7 px-7 py-3.5 text-[0.875rem] font-medium"
          >
            Book Now
            <ArrowRight class="size-3.5" aria-hidden="true" />
          </GradientButton>
        </div>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
