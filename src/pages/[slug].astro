---
import { Image } from 'astro:assets';
import { ArrowRight, Check, Mail, Phone, X } from '@lucide/astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  aboutAddenda,
  allPages,
  bookingUrl,
  contactAddenda,
  contentPages,
  serviceCategories,
  serviceCategoryOrder,
  servicePages,
  teamMembers,
  transformations,
} from '../data/site';

export function getStaticPaths() {
  return allPages
    .filter((page) => page.type !== 'service' && page.type !== 'team-member' && page.slug !== 'team')
    .map((page) => ({
      params: { slug: page.slug },
      props: { page },
    }));
}

const teamIntro = contentPages.find((p) => p.slug === 'team')!;

const categoryAnchors: Record<(typeof serviceCategoryOrder)[number], string> = {
  'Injectables & Fillers': 'injectables-fillers',
  'Skin Renewal & Resurfacing': 'skin-renewal',
  'Hair & Body': 'hair-body',
  Wellness: 'wellness',
  'Skincare Retail': 'skincare-retail',
};

const { page } = Astro.props;
const title = `${page.title} | Access Aesthetics`;
const description = page.summary;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main
    class="bg-[#f9f8f6] pt-20 text-[#141820]"
    x-data="{ selected: null, activeCat: null }"
    x-init="
      const h = window.location.hash.slice(1);
      if (h && document.querySelector(`[data-modal-slug='${h}']`)) selected = h;
      const catSections = Array.from(document.querySelectorAll('[data-cat-section]'));
      if (catSections.length) {
        activeCat = catSections[0].id;
        const catObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => { if (entry.isIntersecting) activeCat = entry.target.id; });
        }, { rootMargin: '-35% 0px -55% 0px', threshold: 0 });
        catSections.forEach((section) => catObserver.observe(section));
      }
    "
  >
    {page.type !== 'services' && (
      <section class="relative isolate overflow-hidden bg-[#0f1d29]">
        <div class="absolute inset-0 -z-20">
          <Image
            src={page.image}
            alt={page.imageAlt}
            class="h-full w-full object-cover opacity-42"
            widths={[720, 960, 1280, 1600]}
            sizes="100vw"
            priority
          />
        </div>
        <div class="absolute inset-0 -z-10 bg-gradient-to-r from-[#07121b]/94 via-[#0f1d29]/78 to-[#0f1d29]/36"></div>
        <div class="absolute inset-x-0 bottom-0 -z-10 h-32 bg-gradient-to-t from-[#f9f8f6] to-transparent"></div>
        <div class="mx-auto flex min-h-[520px] max-w-[calc(1280px+8rem)] items-end px-5 pb-16 pt-24 sm:px-8 lg:min-h-[640px] lg:px-16 lg:pb-24">
          <div data-reveal class="max-w-3xl">
            <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-300">{page.kicker}</p>
            <h1 class="font-display text-[clamp(2.75rem,6vw,6.25rem)] font-normal leading-[0.98] tracking-normal text-white">
              {page.title}
            </h1>
            {'role' in page && <p class="mt-5 text-[0.82rem] font-semibold uppercase tracking-[0.16em] text-brand-200">{page.role}</p>}
            <p class="mt-6 max-w-[60ch] text-[1.125rem] leading-[1.75] text-[#d6e3ea]">
              {page.summary}
            </p>
            <div class="mt-9 flex flex-col gap-4 sm:flex-row">
              <a href={bookingUrl} class="brand-cut-button inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[0.875rem] font-medium text-white transition hover:-translate-y-px">
                Book Your Experience
                <ArrowRight class="size-3.5" aria-hidden="true" />
              </a>
              <a href="/services" class="inline-flex items-center justify-center gap-2 border-b border-white/25 pb-1 text-[0.875rem] font-semibold uppercase tracking-[0.14em] text-white/82 transition hover:border-brand-300 hover:text-white">
                Explore Services
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    {page.type !== 'services' && (
      <section class="px-5 py-16 sm:px-8 lg:px-16 lg:py-24">
        <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.95fr_1.45fr] lg:gap-16">
          <aside data-reveal class="lg:sticky lg:top-24 lg:self-start">
            <div class="bg-white p-6 shadow-soft">
              <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">Access Aesthetics</p>
              <div class="space-y-3 text-sm leading-relaxed text-[#5a6070]">
                <p class="flex gap-3">
                  <Phone class="mt-0.5 size-4 shrink-0 text-brand-600" aria-hidden="true" />
                  <a href="tel:+19859605066" class="transition hover:text-brand-700">985-960-5066</a>
                </p>
                <p class="flex gap-3">
                  <Mail class="mt-0.5 size-4 shrink-0 text-brand-600" aria-hidden="true" />
                  <a href="mailto:info@accessofla.com" class="transition hover:text-brand-700">{'email' in page ? page.email : 'info@accessofla.com'}</a>
                </p>
              </div>
            </div>
          </aside>

          <div data-reveal data-reveal-delay="120">
            <div class="space-y-6 text-[1.0625rem] leading-[1.78] text-[#5a6070]">
              {page.copy.map((paragraph) => <p>{paragraph}</p>)}
            </div>

            {'highlights' in page && page.highlights && (
              <div class="mt-10 grid gap-3 sm:grid-cols-2">
                {page.highlights.map((item) => (
                  <div class="flex items-start gap-3 bg-white p-5 shadow-[0_16px_42px_rgba(20,24,32,0.08),0_1px_4px_rgba(20,24,32,0.04)]">
                    <Check class="mt-0.5 size-4 shrink-0 text-brand-600" stroke-width={2.5} aria-hidden="true" />
                    <span class="text-[0.8rem] font-semibold uppercase tracking-[0.11em] text-[#141820]">{item}</span>
                  </div>
                ))}
              </div>
            )}

            {page.type === 'contact' && (
              <form name="contact" method="POST" data-netlify="true" class="mt-10 bg-white p-6 shadow-soft sm:p-8">
                <input type="hidden" name="form-name" value="contact" />
                <div class="grid gap-5 sm:grid-cols-2">
                  <label class="block">
                    <span class="mb-2 block text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-[#5a6070]">Name</span>
                    <input name="name" required class="w-full bg-[#f4f8fa] px-4 py-3 text-[#141820] outline-none ring-1 ring-transparent transition focus:ring-brand-300" />
                  </label>
                  <label class="block">
                    <span class="mb-2 block text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-[#5a6070]">Email</span>
                    <input type="email" name="email" required class="w-full bg-[#f4f8fa] px-4 py-3 text-[#141820] outline-none ring-1 ring-transparent transition focus:ring-brand-300" />
                  </label>
                </div>
                <label class="mt-5 block">
                  <span class="mb-2 block text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-[#5a6070]">Message</span>
                  <textarea name="message" rows="5" required class="w-full bg-[#f4f8fa] px-4 py-3 text-[#141820] outline-none ring-1 ring-transparent transition focus:ring-brand-300"></textarea>
                </label>
                <button type="submit" class="brand-cut-button mt-6 inline-flex px-7 py-3.5 text-[0.875rem] font-medium text-white">
                  Send Message
                </button>
              </form>
            )}
          </div>
        </div>
      </section>
    )}

    {page.slug === 'contact' && (
      <section class="border-t border-[#edebe7] bg-white px-5 py-16 sm:px-8 lg:px-16 lg:py-24">
        <div class="mx-auto grid max-w-7xl gap-14 lg:grid-cols-2">
          {contactAddenda.map((addendum) => (
            <div id={addendum.slug} data-reveal class="scroll-mt-28">
              <p class="mb-3.5 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">{addendum.kicker}</p>
              <h2 class="font-display text-2xl leading-tight text-ink sm:text-3xl">{addendum.title}</h2>
              <p class="mt-4 text-[1.0625rem] leading-[1.75] text-[#5a6070]">{addendum.summary}</p>
              <div class="mt-5 space-y-4 text-[0.9375rem] leading-[1.75] text-[#5a6070]">
                {addendum.copy.map((paragraph) => <p>{paragraph}</p>)}
              </div>
              <div class="mt-6 grid gap-3 sm:grid-cols-2">
                {addendum.highlights.map((item) => (
                  <div class="flex items-start gap-3 bg-[#f9f8f6] p-4 shadow-[0_16px_42px_rgba(20,24,32,0.06),0_1px_4px_rgba(20,24,32,0.03)]">
                    <Check class="mt-0.5 size-4 shrink-0 text-brand-600" stroke-width={2.5} aria-hidden="true" />
                    <span class="text-[0.78rem] font-semibold uppercase tracking-[0.1em] text-[#141820]">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {page.type === 'services' && (
      <>
        <section class="relative overflow-hidden bg-white px-5 pb-14 pt-28 sm:px-8 sm:pt-32 lg:px-16 lg:pb-20 lg:pt-40">
          <div class="mx-auto max-w-[calc(1280px+8rem)]">
            <div data-reveal class="max-w-2xl">
              <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">{page.kicker} &middot; Slidell, LA</p>
              <h1 class="font-display text-[clamp(2.5rem,4.5vw,4rem)] font-normal leading-[1.08] tracking-normal text-ink">
                {page.title}
              </h1>
              <p class="mt-5 max-w-[52ch] text-[1.0625rem] leading-[1.75] text-[#5a6070]">
                {page.summary}
              </p>
              <div class="mt-9 flex flex-wrap items-center gap-6">
                <a href={bookingUrl} class="brand-cut-button inline-flex items-center gap-2 px-7 py-3.5 text-[0.875rem] font-medium text-white transition hover:-translate-y-px">
                  Book your consult
                  <ArrowRight class="size-3.5" aria-hidden="true" />
                </a>
                <a href={`#${categoryAnchors[serviceCategoryOrder[0]]}`} class="inline-flex items-center gap-1.5 border-b border-[#e4e0db] pb-1 text-[0.9375rem] text-[#141820] transition hover:border-brand-400 hover:text-brand-700">
                  Browse by category
                </a>
              </div>
            </div>
          </div>
        </section>

        <div
          class="sticky top-20 z-40 -mx-5 mb-8 overflow-x-auto border-b border-[#edebe7] bg-[#f9f8f6]/95 px-5 py-3 backdrop-blur-md sm:-mx-8 sm:px-8 lg:hidden"
        >
          <ul class="no-scrollbar flex gap-6 whitespace-nowrap">
            {serviceCategoryOrder.map((category) => (
              <li>
                <a
                  href={`#${categoryAnchors[category]}`}
                  x-bind:class={`activeCat === '${categoryAnchors[category]}' ? 'text-brand-700 font-semibold' : 'text-[#5a6070]'`}
                  class="inline-block py-1 text-[0.82rem] font-medium uppercase tracking-[0.08em] transition"
                >
                  {category}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="mx-auto grid max-w-[calc(1280px+8rem)] gap-12 px-5 pb-24 sm:px-8 lg:grid-cols-[260px_1fr] lg:gap-16 lg:px-16">
          <aside class="hidden lg:sticky lg:top-28 lg:block lg:self-start">
            <p class="mb-5 text-[0.7rem] font-medium uppercase tracking-[0.22em] text-[#8b929e]">Categories</p>
            <ul class="flex flex-col">
              {serviceCategoryOrder.map((category, idx) => (
                <li>
                  <a
                    href={`#${categoryAnchors[category]}`}
                    class="flex items-baseline gap-3.5 border-b border-[#edebe7] py-3.5 text-sm transition"
                    x-bind:class={`activeCat === '${categoryAnchors[category]}' ? 'text-brand-700 font-semibold' : 'text-[#5a6070] hover:text-[#141820]'`}
                  >
                    <span
                      class="text-[0.72rem] font-medium tabular-nums transition"
                      x-bind:class={`activeCat === '${categoryAnchors[category]}' ? 'text-brand-600' : 'text-[#8b929e]'`}
                    >
                      {String(idx + 1).padStart(2, '0')}
                    </span>
                    <span>{category}</span>
                  </a>
                </li>
              ))}
            </ul>
            <a href={bookingUrl} class="mt-8 inline-flex items-center gap-2 border-b border-[#e4e0db] pb-1 text-[0.85rem] text-[#141820] transition hover:border-brand-400 hover:text-brand-700">
              Not sure where to start? Book a consult
            </a>
          </aside>

          <div>
            {serviceCategoryOrder.map((category, idx) => {
              const services = servicePages.filter((service) => serviceCategories[service.slug] === category);
              const isRetail = category === 'Skincare Retail';
              return (
                <section id={categoryAnchors[category]} data-cat-section class="scroll-mt-40 lg:scroll-mt-32">
                  {idx > 0 && <div class="mt-14 lg:mt-20" />}
                  <div class="mb-8 flex flex-wrap items-baseline gap-4 border-b border-[#edebe7] pb-5">
                    <span class="font-display text-[0.85rem] font-medium text-brand-600">{String(idx + 1).padStart(2, '0')}</span>
                    <h2 class="font-display text-[clamp(1.75rem,2.6vw,2.5rem)] leading-tight text-ink">{category}</h2>
                    <span class="ml-auto whitespace-nowrap text-[0.8125rem] text-[#8b929e]">
                      {services.length} {isRetail ? (services.length === 1 ? 'product line' : 'product lines') : services.length === 1 ? 'treatment' : 'treatments'}
                    </span>
                  </div>

                  <div class="grid gap-5 sm:grid-cols-2">
                    {services.map((service) =>
                      isRetail ? (
                        <article class="bg-brand-50 p-7 ring-1 ring-brand-100 transition hover:ring-brand-300">
                          <p class="mb-2.5 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-brand-600">{service.kicker}</p>
                          <h3 class="font-display text-xl leading-snug text-ink">{service.title}</h3>
                          <p class="mt-2.5 text-[0.9rem] leading-[1.65] text-[#5a6070]">{service.summary}</p>
                        </article>
                      ) : (
                        <article class="group flex flex-col bg-white p-7 shadow-[0_16px_40px_rgba(20,24,32,0.06),0_1px_4px_rgba(20,24,32,0.03)] transition hover:-translate-y-1 hover:shadow-soft">
                          <p class="mb-2.5 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-brand-600">{service.kicker}</p>
                          <h3 class="font-display text-xl leading-snug text-ink">{service.title}</h3>
                          <p class="mt-2.5 flex-1 text-[0.9rem] leading-[1.65] text-[#5a6070]">{service.summary}</p>
                          <div class="mt-5 flex items-center justify-between gap-4 border-t border-[#edebe7] pt-4">
                            <button
                              type="button"
                              x-on:click={`selected = '${service.slug}'`}
                              class="inline-flex items-center gap-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-[#141820] underline decoration-brand-300 decoration-2 underline-offset-4 transition group-hover:text-brand-700"
                            >
                              Learn more
                              <ArrowRight class="size-3 transition group-hover:translate-x-0.5" aria-hidden="true" />
                            </button>
                            <a href={bookingUrl} class="text-[0.8rem] text-[#8b929e] transition hover:text-brand-600">Book &rarr;</a>
                          </div>
                        </article>
                      )
                    )}
                  </div>

                  {isRetail && (
                    <p class="mt-6 text-[0.8125rem] text-[#8b929e]">
                      Product lines are available in-studio &mdash; ask your provider for a personalized regimen at your next visit.
                    </p>
                  )}
                </section>
              );
            })}
          </div>
        </div>

        <section class="bg-brand-800">
          <div class="mx-auto flex max-w-[calc(1280px+8rem)] flex-col items-start gap-8 px-5 py-16 sm:px-8 sm:py-20 lg:flex-row lg:items-center lg:justify-between lg:px-16">
            <div>
              <h2 class="font-display max-w-xl text-[clamp(1.875rem,3vw,2.75rem)] leading-tight text-white">
                Not sure which treatment fits your goals?
              </h2>
              <p class="mt-3 max-w-lg text-[0.95rem] text-white/60">
                Start with a consultation &mdash; your provider will build a plan around your skin, your timeline, and your comfort level.
              </p>
            </div>
            <a
              href={bookingUrl}
              class="inline-flex shrink-0 items-center gap-2 whitespace-nowrap bg-white px-7 py-3.5 text-[0.875rem] font-medium text-brand-800 transition hover:bg-brand-50 hover:-translate-y-px"
            >
              Book your consult
              <ArrowRight class="size-3.5" aria-hidden="true" />
            </a>
          </div>
        </section>
      </>
    )}

    {page.slug === 'about' && (
      <section class="border-t border-[#edebe7] bg-[#f9f8f6]">
        {aboutAddenda.map((addendum) => (
          <div id={addendum.slug} data-reveal class="grid scroll-mt-28 lg:grid-cols-2">
            <div
              class="min-h-[320px] bg-white lg:min-h-[560px]"
              style={`background-image: url(${addendum.image.src}); background-size: contain; background-repeat: no-repeat; background-position: center;`}
              role="img"
              aria-label={addendum.imageAlt}
            ></div>
            <div class="flex flex-col justify-center px-5 py-16 sm:px-8 lg:px-16 lg:py-24">
              <p class="mb-3.5 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">{addendum.kicker}</p>
              <h2 class="font-display text-[clamp(2.125rem,3.2vw,3.375rem)] font-normal leading-[1.1] tracking-[-0.01em] text-ink">
                {addendum.title}
              </h2>
              <p class="mt-4 text-[1.0625rem] leading-[1.75] text-[#5a6070]">{addendum.summary}</p>
              <div class="mt-5 space-y-4 text-[0.9375rem] leading-[1.75] text-[#5a6070]">
                {addendum.copy.map((paragraph) => <p>{paragraph}</p>)}
              </div>
              <div class="mt-6 grid gap-3 sm:grid-cols-2">
                {addendum.highlights.map((item) => (
                  <div class="flex items-start gap-3 bg-white p-4 shadow-[0_16px_42px_rgba(20,24,32,0.06),0_1px_4px_rgba(20,24,32,0.03)]">
                    <Check class="mt-0.5 size-4 shrink-0 text-brand-600" stroke-width={2.5} aria-hidden="true" />
                    <span class="text-[0.78rem] font-semibold uppercase tracking-[0.1em] text-[#141820]">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </section>
    )}

    {page.slug === 'about' && (
      <section id="meet-our-team" class="bg-white px-5 py-16 sm:px-8 lg:px-16 lg:py-24">
        <div class="mx-auto max-w-7xl">
          <div class="mx-auto mb-12 max-w-3xl text-center">
            <p class="mb-3.5 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">{teamIntro.kicker}</p>
            <h2 class="font-display text-[clamp(2.125rem,3.2vw,3.375rem)] font-normal leading-[1.1] tracking-[-0.01em] text-ink">
              {teamIntro.title}
            </h2>
            {teamIntro.copy.map((paragraph) => (
              <p class="mt-5 text-[1.0625rem] leading-[1.75] text-[#5a6070]">{paragraph}</p>
            ))}
          </div>

          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
            {teamMembers.map((member) => (
              <button
                type="button"
                x-on:click={`selected = '${member.slug}'`}
                class="group flex flex-col bg-[#f9f8f6] text-left shadow-[0_18px_48px_rgba(20,24,32,0.08),0_1px_4px_rgba(20,24,32,0.04)] transition hover:-translate-y-1 hover:shadow-soft"
              >
                <Image src={member.image} alt={member.imageAlt} class="aspect-[4/5] w-full object-cover" widths={[360, 520, 720]} sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw" />
                <div class="flex flex-1 flex-col p-6">
                  <h3 class="font-display text-2xl leading-tight text-ink">{member.name}</h3>
                  <p class="mt-2 text-[0.64rem] font-semibold uppercase tracking-[0.16em] text-brand-600">{member.title}</p>
                  <p class="mt-4 flex-1 text-sm leading-[1.7] text-[#5a6070]">{member.summary}</p>
                  <span class="mt-6 inline-flex items-center gap-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-brand-700 underline decoration-brand-300 decoration-2 underline-offset-4">
                    Meet {member.name.split(' ')[0]}
                    <ArrowRight class="size-3.5 transition group-hover:translate-x-1" aria-hidden="true" />
                  </span>
                </div>
              </button>
            ))}
          </div>
        </div>
      </section>
    )}

    {page.type === 'transformations' && (
      <section class="bg-white px-5 py-16 sm:px-8 lg:px-16 lg:py-24">
        <div class="mx-auto grid max-w-7xl gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {transformations.map((item, index) => (
            <figure class="bg-[#f9f8f6] p-3 shadow-[0_18px_48px_rgba(20,24,32,0.08),0_1px_4px_rgba(20,24,32,0.04)]">
              <Image src={item.image} alt={item.alt} class="aspect-square w-full object-cover" widths={[420, 640, 960]} sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw" />
              <figcaption class="flex items-center justify-between gap-4 px-1.5 pb-1 pt-3.5 text-xs font-semibold uppercase tracking-[0.16em] text-[#8b929e]">
                <span>{item.label}</span>
                <span>{String(index + 1).padStart(2, '0')} / {String(transformations.length).padStart(2, '0')}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    {page.type === 'services' && (
      <div x-show="selected !== null" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-6">
        <div
          x-show="selected !== null"
          x-transition.opacity
          x-on:click="selected = null"
          class="absolute inset-0 bg-black/50"
        >
        </div>

        {servicePages.map((service) => (
          <div
            data-modal-slug={service.slug}
            x-show={`selected === '${service.slug}'`}
            x-cloak
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 scale-100"
            x-transition:leave-end="opacity-0 scale-95"
            class="relative max-h-[85vh] w-full max-w-2xl overflow-y-auto bg-white p-7 shadow-lift sm:p-10"
          >
            <button
              type="button"
              x-on:click="selected = null"
              class="absolute right-5 top-5 flex size-9 items-center justify-center rounded-full bg-[#f9f8f6] text-[#5a6070] transition hover:bg-[#eceae7]"
              aria-label="Close"
            >
              <X class="size-4" aria-hidden="true" />
            </button>

            <p class="text-[0.64rem] font-semibold uppercase tracking-[0.2em] text-brand-500">{service.kicker}</p>
            <h2 class="mt-2 font-display text-3xl leading-tight text-ink">{service.title}</h2>
            <div class="mt-5 space-y-4 text-[0.9375rem] leading-[1.75] text-[#5a6070]">
              {service.copy.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
            <a
              href={bookingUrl}
              class="brand-cut-button mt-7 inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[0.875rem] font-medium text-white transition hover:-translate-y-px"
            >
              Book Now
              <ArrowRight class="size-3.5" aria-hidden="true" />
            </a>
          </div>
        ))}
      </div>
    )}

    {page.slug === 'about' && (
      <div x-show="selected !== null" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-6">
        <div
          x-show="selected !== null"
          x-transition.opacity
          x-on:click="selected = null"
          class="absolute inset-0 bg-black/50"
        >
        </div>

        {teamMembers.map((member) => (
          <div
            data-modal-slug={member.slug}
            x-show={`selected === '${member.slug}'`}
            x-cloak
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 scale-95"
            x-transition:enter-end="opacity-100 scale-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 scale-100"
            x-transition:leave-end="opacity-0 scale-95"
            class="relative max-h-[85vh] w-full max-w-2xl overflow-y-auto bg-white p-7 shadow-lift sm:p-10"
          >
            <button
              type="button"
              x-on:click="selected = null"
              class="absolute right-5 top-5 flex size-9 items-center justify-center rounded-full bg-[#f9f8f6] text-[#5a6070] transition hover:bg-[#eceae7]"
              aria-label="Close"
            >
              <X class="size-4" aria-hidden="true" />
            </button>

            <div class="flex items-center gap-5">
              <Image src={member.image} alt={member.imageAlt} class="size-20 shrink-0 rounded-full object-cover" widths={[120, 160]} sizes="80px" />
              <div>
                <h2 class="font-display text-2xl leading-tight text-ink">{member.name}</h2>
                <p class="mt-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-brand-600">{member.title}</p>
              </div>
            </div>
            <div class="mt-6 space-y-4 text-[0.9375rem] leading-[1.75] text-[#5a6070]">
              {member.copy.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
            <div class="mt-7 flex flex-wrap gap-4">
              <a
                href={`mailto:${member.email}`}
                class="inline-flex items-center gap-2 border border-brand-200 px-6 py-3 text-[0.8rem] font-semibold uppercase tracking-[0.1em] text-brand-700 transition hover:border-brand-400"
              >
                <Mail class="size-4" aria-hidden="true" />
                Email {member.name.split(' ')[0]}
              </a>
              <a
                href={bookingUrl}
                class="brand-cut-button inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[0.875rem] font-medium text-white transition hover:-translate-y-px"
              >
                Book Now
                <ArrowRight class="size-3.5" aria-hidden="true" />
              </a>
            </div>
          </div>
        ))}
      </div>
    )}
  </main>
  <Footer />
</BaseLayout>
