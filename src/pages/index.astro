          <p class="mb-7 text-[0.7rem] font-medium uppercase tracking-[0.22em] text-[#8b929e]">Recognized By</p>
          <div class="overflow-hidden sm:hidden">
            <div class="animate-marquee flex w-max">
              {[...recognitions, ...recognitions].map((item) => (
                <div class="flex items-center gap-4 px-8 py-1 text-left whitespace-nowrap">
                  <Image src={item.image} alt={item.alt} class="h-auto w-16 shrink-0" widths={[64, 96]} sizes="64px" />
                  <div>
                    <p class="text-[0.9rem] font-semibold leading-[1.35] text-[#141820]">{item.title}</p>
                    <p class="mt-0.5 text-[0.78rem] text-[#5a6070]">{item.source}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="hidden items-center gap-7 sm:flex sm:flex-row sm:flex-wrap sm:justify-center sm:gap-0">
            {recognitions.map((item, index) => (
              <div
                class={`flex items-center gap-4 px-11 py-1 text-left ${index > 0 ? 'sm:border-l sm:border-[#edebe7]' : ''}`}
              >
                <Image src={item.image} alt={item.alt} class="h-auto w-16 shrink-0" widths={[64, 96]} sizes="64px" />
                <div>
                  <p class="text-[0.9rem] font-semibold leading-[1.35] text-[#141820]">{item.title}</p>
                  <p class="mt-0.5 text-[0.78rem] text-[#5a6070]">{item.source}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <PreFooterCTA
      eyebrow="Your next step starts here"
      titleLines={['Begin Your Journey', 'to Radiance']}
      copy="A complimentary consultation is where every transformation begins. Meet with our team, share your goals, and leave with a personalized plan built entirely around you."
      href={bookingUrl}
      cta="Book Your Consultation"
      fromWhite
    />
  </main>
  <Footer />
