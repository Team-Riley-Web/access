---
import { Image } from 'astro:assets';
import {
  ArrowRight,
  Check,
  LockKeyhole,
  ShieldCheck,
  Sparkles,
  UsersRound,
} from '@lucide/astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PreFooterCTA from '../components/PreFooterCTA.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import beforeAfter1 from '../assets/images/before-after-1.jpg';
import beforeAfter2 from '../assets/images/before-after-2.jpg';
import beforeAfter3 from '../assets/images/before-after-3.jpg';
import beforeAfter4 from '../assets/images/before-after-4.jpg';
import beforeAfter5 from '../assets/images/before-after-5.jpg';
import beforeAfter6 from '../assets/images/before-after-6.jpg';
import beforeAfter7 from '../assets/images/before-after-7.jpg';
import beforeAfter8 from '../assets/images/before-after-8.jpg';
import beforeAfter9 from '../assets/images/before-after-9.jpg';
import marbleBackground from '../assets/images/bg.jpg';
import homeHeroImage from '../assets/images/home-hero.png';
import service3Image from '../assets/images/service-3.jpeg';
import serviceImage from '../assets/images/service.png';
import service2Image from '../assets/images/service2.png';
import teamAmanda from '../assets/images/team-amanda.jpg';
import teamCourtney from '../assets/images/team-courtney.jpg';
import teamHarley from '../assets/images/team-harley.jpg';
import teamImage from '../assets/images/team.jpg';
import teamMelissa from '../assets/images/team-melissa.jpg';
import meetingImage from '../assets/images/meeting.jpeg';
import northshoresBestBadge from '../assets/images/NorthshoresBest.avif';
import morpheus8VerifiedBadge from '../assets/images/morpheus8.png';
import morpheus8TopProviderBadge from '../assets/images/top-morpheus8.png';

const bookingUrl = 'https://www.myaestheticspro.com/';

const starPath = 'M12 2l2.9 6.6 7.1.7-5.4 4.8 1.6 7-6.2-3.8-6.2 3.8 1.6-7L2 9.3l7.1-.7z';

const googleReviews = [
  {
    name: 'Kathy Giusti',
    meta: '1 review',
    time: '9 months ago',
    text: "I had an excellent experience at Access Aesthetics with Harley Lonardo and Courtney Muller, NP. Harley was professional and knowledgeable, recommending the perfect IPL treatment for my dark spots and sun damage-I'm thrilled with the results. Courtney did amazing work with my lip fillers and Botox, giving me a natural, refreshed look. I also love the ZO skincare products Harley suggested for my daily routine. Highly recommend!",
  },
  {
    name: 'Tiffany Woods',
    meta: '5 reviews · 2 photos',
    time: '9 months ago',
    text: 'I was very skeptical of Aesthetic clinics and researched so many before choosing Access Aesthetics. The fact that they have a Nurse Practitioner performing services really impressed me. Courtney Muller, NP is amazing!!! She takes time to explain procedures and will answer any question you have! Due to having a connective tissue disorder I was full of questions. Courtney has gone above and beyond by making sure I underwent the treatments best for me! The entire Access Aesthetics team is a joy to interact with and make visits so easy!',
  },
  {
    name: 'Kaitlin Melton',
    meta: '4 reviews · 3 photos',
    time: '10 months ago',
    text: 'I love my access family! Only company I would trust to do anything. Courtney & Harley are both AMAZING! The process is sooo easy and they walk you through every step specially if you are newer to the treatments. 100/10 recommend!!!',
  },
  {
    name: 'Megan Hellbach',
    meta: '3 reviews · 3 photos',
    time: '10 months ago',
    text: '10/10 experience every time! Harley is truly a master of her craft (i mean just look at the transformation of my nonexistent brows to perfectly sculpted ones!) takes time to listen and provide exactly what you want/ask for. amanda and courtney are always the most welcoming! they truly care about your satisfaction, and creating lasting relationships with their clients! i literally recommend them to everyone!',
  },
  {
    name: 'Madison Kadinger Macaluso',
    meta: '9 reviews',
    time: '9 months ago',
    text: 'Courtney is the best! It was my first time getting Botox and I was so nervous. She calmed my nerves and made sure I felt comfortable the whole time. Would highly recommend Access Aesthetics and Courtney!',
  },
  {
    name: 'Allexxandra Neyland',
    meta: '2 reviews',
    time: '9 months ago',
    text: 'Courtney Muller did a great job at putting me at ease during my Botox appointment! She was very informative also! I had a painless experience! I will definitely be returning to see her for more Botox and other services!',
  },
  {
    name: 'Cameron Bryant-Echols',
    meta: '1 review',
    time: '9 months ago',
    text: "Loveee coming here, the entire staff is soo friendly. Harley never misses a beat with my eyebrows, a LITERAL QUEEN. And Courtney the NP, seriously don't trust anyone else with my Botox. She has the best bedside manner and her work is amazing",
  },
  {
    name: 'Madison Wuertz',
    meta: '2 reviews',
    time: 'Edited 9 months ago',
    text: 'The staff at Access is TOP TIER! From the moment you walk in you feel apart of their family! Courtney has my skin feeling vibrant and as healthy as my teenage years! Love going to see the Access girls!!💙💙💙',
  },
  {
    name: 'Shannon Lipps',
    meta: '5 reviews',
    time: '8 months ago',
    text: "I have to say, getting a facial or any treatment from Melissa is an absolute pleasure. As a landscape contractor with 25 years of experience, I've seen a lot, but Melissa has truly transformed my sun damaged skin into beautiful, healthy skin—and for me, now in my mid-40s, every time I get a treatment from her, I feel like I look younger and younger. She's sweet, funny, friendly, and incredibly knowledgeable in her field, always bringing a positive attitude. I genuinely love my appointments with her and can't recommend her enough!",
  },
];

const recognitions = [
  { image: northshoresBestBadge, alt: "The Northshore's Best 2025 seal", title: "The Northshore's Best 2025", source: 'Sophisticated Woman Magazine' },
  { image: morpheus8TopProviderBadge, alt: 'Morpheus8 Top Provider 2025 badge', title: 'Morpheus8 Top Provider 2025', source: 'InMode' },
  { image: morpheus8VerifiedBadge, alt: 'Morpheus8 Verified Provider badge', title: 'Morpheus8 Verified Provider', source: 'InMode' },
];

const trustItems = [
  { icon: ShieldCheck, title: 'Medical expertise', copy: 'Licensed aesthetic providers' },
  { icon: Sparkles, title: 'Natural results', copy: 'Refined, never overdone' },
  { icon: LockKeyhole, title: 'Safety first', copy: 'Personalized treatment plans' },
  { icon: UsersRound, title: 'Trusted by patients', copy: '5 star experience' },
];

const serviceGroups = [
  {
    kicker: 'Glowing Skin',
    title: 'Professional care for refreshed skin.',
    copy:
      'Aesthetic skin treatments support confidence, self-care, and long-term skin health by addressing tone, texture, acne, fine lines, and loss of elasticity.',
    image: serviceImage,
    imageAlt: 'Access Aesthetics treatment room',
    items: ['Morpheus 8 RF Microneedling', 'Rejuvapen Microneedling', 'Laser Hair Removal', 'Chemical Peels & Facials'],
  },
  {
    kicker: 'Restorative Beauty',
    title: 'Subtle rejuvenation with a glow.',
    copy:
      'Restorative procedures help soften lines, restore volume, reduce sun damage, and improve tone so every treatment feels personalized and balanced.',
    image: service2Image,
    imageAlt: 'Aesthetic injectable treatment in progress',
    reverse: true,
    items: ['Neurotoxins', 'Dermal Fillers', 'IPL Therapy', 'Bio-Filler & PRP'],
  },
  {
    kicker: 'Balanced Radiance',
    title: 'Aesthetic wellness for lasting confidence.',
    copy:
      'From advanced rejuvenation to hydration and therapeutic therapies, full-body care supports outer radiance and a renewed sense of vitality.',
    image: service3Image,
    imageAlt: 'Calming facial treatment at Access Aesthetics',
    items: ['Vitamin Injections', 'Lash & Brow Services', 'Biostimulators', 'Skin Care'],
  },
];

const team = [
  {
    name: 'Amanda Clementi',
    title: 'Director of Aesthetics & Health and Wellness',
    copy:
      'Amanda’s goal at Access Aesthetics is to empower clients to feel confident and rejuvenated through high-quality, personalized beauty and wellness treatments.',
    image: teamAmanda,
    href: '/amanda-clementi',
    cta: 'Meet Amanda',
  },
  {
    name: 'Courtney Muller',
    title: 'MSN, APRN, FNP-C',
    copy:
      'With over 13 years of experience, Courtney brings enthusiasm, compassion, and a warm personality to every client relationship.',
    image: teamCourtney,
    href: '/courtney-miller',
    cta: 'Meet Courtney',
  },
  {
    name: 'Harley Lonardo',
    title: 'Advanced Medical Esthetician',
    copy:
      'Harley excels in both medical and beauty aesthetic services, tailoring each treatment to her client’s needs with skill and care.',
    image: teamHarley,
    href: '/harley-lonardo',
    cta: 'Meet Harley',
  },
  {
    name: 'Melissa Holley',
    title: 'Medical Esthetician',
    copy:
      'Melissa has spent more than 20 years helping women love their skin and create plans that support their goals.',
    image: teamMelissa,
    href: '/melissa-holley',
    cta: 'Meet Melissa',
  },
];

const teamHotspots = [
  { name: 'Melissa Holley', title: 'Medical Esthetician', href: '/about#melissa-holley', x: '18%', y: '80%' },
  { name: 'Courtney Muller', title: 'MSN, APRN, FNP-C', href: '/about#courtney-miller', x: '41%', y: '80%' },
  { name: 'Amanda Clementi', title: 'Director of Aesthetics & Health and Wellness', href: '/about#amanda-clementi', x: '60%', y: '80%' },
  { name: 'Harley Lonardo', title: 'Advanced Medical Esthetician', href: '/about#harley-lonardo', x: '81%', y: '80%' },
];

const transformations = [
  { image: beforeAfter1, alt: 'Before and after skin treatment result', label: 'Skin Transformation' },
  { image: beforeAfter2, alt: 'Before and after neck treatment result', label: 'Neck Transformation' },
  { image: beforeAfter3, alt: 'Before and after lip treatment result', label: 'Lip Transformation' },
  { image: beforeAfter4, alt: 'Before and after skin rejuvenation result', label: 'Skin Transformation' },
  { image: beforeAfter5, alt: 'Before and after eye treatment result', label: 'Eye Transformation' },
  { image: beforeAfter6, alt: 'Before and after eyebrow treatment result', label: 'Eyebrow Transformation' },
  { image: beforeAfter7, alt: 'Before and after lip treatment result', label: 'Lip Transformation' },
  { image: beforeAfter8, alt: 'Before and after skin treatment result', label: 'Skin Transformation' },
  { image: beforeAfter9, alt: 'Before and after lip treatment result', label: 'Lip Transformation' },
];

const transformationSlides = Array.from({ length: Math.ceil(transformations.length / 3) }, (_, index) =>
  transformations.slice(index * 3, index * 3 + 3).map((item, itemIndex) => ({
    ...item,
    originalIndex: index * 3 + itemIndex,
  }))
);

const reviewSlides = Array.from({ length: Math.ceil(googleReviews.length / 3) }, (_, index) =>
  googleReviews.slice(index * 3, index * 3 + 3)
);
---

<BaseLayout
  title="Access Aesthetics | Medical Spa in Slidell, LA"
  description="Access Aesthetics is a Slidell, Louisiana medical spa offering injectables, skin treatments, laser services, facials, and aesthetic wellness care."
>
  <Header />
  <main id="home" class="overflow-hidden bg-[#f9f8f6] text-[#141820]">
    <section class="bg-white pt-20">
      <div class="relative isolate overflow-hidden bg-white lg:min-h-[calc(100vh-12rem)]">
        <div class="absolute inset-y-0 right-0 -z-30 hidden h-full w-[62%] lg:block">
          <Image
            src={homeHeroImage}
            alt="Client receiving an injectable aesthetic treatment"
            class="h-full w-full object-cover object-[55%_25%]"
            widths={[720, 960, 1280, 1448]}
            sizes="62vw"
            priority
          />
        </div>
        <Image
          src={northshoresBestBadge}
          alt="The Northshore's Best 2025 award — Sophisticated Woman"
          class="absolute right-16 bottom-8 z-10 hidden w-28 drop-shadow-[0_10px_24px_rgba(0,61,102,0.35)] lg:block"
          widths={[108, 160]}
          sizes="112px"
        />
        <svg
          class="pointer-events-none absolute inset-y-0 right-0 z-0 hidden h-full w-[62%] text-brand-300 [mask-image:linear-gradient(to_right,black_0%,black_52%,transparent_78%)] lg:block"
          viewBox="0 0 800 760"
          preserveAspectRatio="xMidYMid slice"
          aria-hidden="true"
        >
          <circle cx="370" cy="380" r="260" fill="none" stroke="currentColor" stroke-width="1" opacity="0.26" />
          <circle cx="370" cy="380" r="380" fill="none" stroke="currentColor" stroke-width="1" opacity="0.22" />
        </svg>
        <div class="absolute inset-0 -z-20 hidden bg-gradient-to-r from-[#D6DEFA66] via-white from-[0%] via-white via-[49%] to-white/0 to-[78%] lg:block"></div>
        <div class="absolute inset-x-0 bottom-0 -z-20 hidden h-32 bg-gradient-to-t from-white to-transparent lg:block"></div>

        <div class="relative z-10 mx-auto flex lg:min-h-[calc(100vh-12rem)] max-w-[calc(1280px+8rem)] items-center px-5 py-10 sm:px-8 lg:px-16 lg:py-22">
          <div class="w-full max-w-[56rem] text-center lg:text-left">
            <p class="mb-7 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">
              Medical aesthetics. Personalized for you.
            </p>
            <h1 class="shimmer-text font-display text-[clamp(4rem,8vw,8.5rem)] font-[500] leading-[0.82] tracking-normal lg:-translate-x-2.5">
              Radiance Redefined
            </h1>
            <p class="mx-auto mt-6 max-w-[34ch] text-lg leading-[1.7] text-[#5a6070] lg:mx-0 lg:max-w-none">
              Evidence based treatments. Expert care. Results that look like you,<br class="sm:hidden" /> only refreshed.
            </p>
            <div class="mt-10 flex flex-col items-center gap-5 sm:flex-row sm:justify-center lg:justify-start">
              <a
                href={bookingUrl}
                class="brand-cut-button inline-flex items-center gap-2 px-7 py-3.5 text-[0.9375rem] font-medium text-white transition hover:-translate-y-px"
              >
                Book your consult
              </a>
              <a
                href="/services"
                class="group inline-flex items-center gap-1.5 border-b border-[#e4e0db] pb-0.5 text-[0.9375rem] text-[#141820] transition hover:border-brand-500 hover:text-brand-700"
              >
                Explore treatments
                <ArrowRight class="size-4 transition group-hover:translate-x-1" aria-hidden="true" />
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="relative overflow-hidden lg:hidden">
        <Image
          src={homeHeroImage}
          alt="Client receiving an injectable aesthetic treatment"
          class="h-[23rem] w-full object-cover object-[55%_25%] sm:h-96"
          widths={[720, 960]}
          sizes="100vw"
        />
        <Image
          src={northshoresBestBadge}
          alt="The Northshore's Best 2025 award — Sophisticated Woman"
          class="absolute right-4 top-4 z-10 w-20 drop-shadow-[0_10px_24px_rgba(0,61,102,0.35)]"
          widths={[88, 132]}
          sizes="80px"
        />
      </div>

      <div class="border-t border-brand-100 bg-brand-50">
        <div class="overflow-hidden sm:hidden">
          <div class="animate-marquee flex w-max">
            {
              [...trustItems, ...trustItems].map(({ icon: Icon, title, copy }, i) => (
                <div class="flex items-center gap-3.5 border-r border-brand-100 px-7 py-5 whitespace-nowrap">
                  <Icon class="size-5 shrink-0 text-brand-700" stroke-width={1.75} aria-hidden="true" />
                  <div>
                    <p class="text-[0.875rem] font-semibold text-[#141820]">{title}</p>
                    <p class="text-[0.75rem] text-[#5a6070]">{copy}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
        <div class="mx-auto hidden sm:grid max-w-[calc(1280px+8rem)] px-5 sm:grid-cols-2 sm:px-8 lg:grid-cols-4 lg:px-16">
          {
            trustItems.map(({ icon: Icon, title, copy }, index) => (
              <div data-reveal data-reveal-delay={index * 110} class="flex items-center gap-4 border-brand-100 py-7 lg:border-r lg:px-8 first:lg:pl-0 last:lg:border-r-0 last:lg:pr-0">
                <Icon class="size-7 shrink-0 text-brand-700" stroke-width={1.75} aria-hidden="true" />
                <div>
                  <p class="mb-0.5 text-[0.9375rem] font-semibold text-[#141820]">{title}</p>
                  <p class="text-[0.8125rem] text-[#5a6070]">{copy}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="about" class="overflow-hidden bg-[#0f1d29]">
      <div class="grid lg:grid-cols-2">
        <div class="order-2 lg:order-1 relative min-h-[420px] overflow-hidden lg:min-h-[680px]">
          <Image
            src={meetingImage}
            alt="Access Aesthetics team meeting with a new client"
            class="absolute inset-0 h-full w-full object-cover object-top"
            widths={[720, 960, 1280]}
            sizes="(min-width: 1024px) 50vw, 100vw"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-[#0f1d29]/10 via-transparent to-[#0f1d29]/70 lg:bg-gradient-to-l"></div>
        </div>

        <div class="order-1 lg:order-2 relative flex w-full items-center overflow-hidden px-6 py-16 sm:px-10 lg:px-16 lg:py-32">
          <div class="absolute -right-24 top-20 h-72 w-72 rounded-full bg-brand-500/18 blur-3xl"></div>
          <div class="absolute bottom-0 left-12 h-56 w-56 rounded-full bg-brand-300/10 blur-3xl"></div>
          <div data-reveal class="relative mx-auto max-w-2xl">
            <p class="mb-4 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-300">Welcome To Access Aesthetics</p>
            <h2 class="font-display text-[clamp(2.125rem,3.2vw,3.375rem)] font-normal leading-[1.1] tracking-[-0.01em] text-white">
              Where innovation meets beauty.
            </h2>
            <p class="mt-6 text-lg leading-[1.75] text-[#d6e3ea]">
              From Plexr Plasma and Botox to injectable fillers and transformative spa therapies, licensed experts curate minimally invasive experiences that elevate your beauty with thoughtful, personalized service.
            </p>
            <p class="mt-4 text-lg leading-[1.75] text-[#b9cbd5]">
              At Access, appearances are only part of the story. The goal is a renewed sense of self supported by care, comfort, and modern aesthetic technology.
            </p>
            <div class="pt-8">
              <a
                href={bookingUrl}
                class="brand-cut-button inline-flex items-center gap-2 px-7 py-3.5 text-[0.9375rem] font-medium text-white transition hover:-translate-y-px"
              >
                Book your consult
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section
      id="services"
      class="relative overflow-hidden border-t border-[#edebe7] px-5 py-20 sm:px-10 lg:px-20 lg:py-28"
      style={`background-image: url(${marbleBackground.src}); background-size: cover; background-position: center;`}
    >
      <div class="absolute inset-0 bg-white/42"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-white/58 via-white/32 to-[#eef7fb]/38"></div>
      <div class="relative mx-auto max-w-7xl" x-data="{ active: 0, _tx: 0 }">
        <div data-reveal class="mb-12">
          <p class="mb-3.5 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">
            Treatments for skin, structure, and glow.
          </p>
          <h2 class="font-display text-[clamp(2.25rem,3.4vw,3.75rem)] font-medium leading-[1.05] tracking-[-0.01em] text-ink">
            Premier Aesthetic Experience
          </h2>
          <p class="mt-6 text-[1.0625rem] leading-[1.75] text-[#5a6070]">
            Explore each service focus one at a time, then book a consult for a plan shaped around your skin, goals, and comfort.
          </p>
        </div>

        <div data-reveal data-reveal-delay="130" class="relative">
          <div class="no-scrollbar overflow-x-auto pb-1">
          <div class="relative flex min-w-[680px] border-b border-[#d9e2e6]" role="tablist" aria-label="Service categories">
            {
              serviceGroups.map((service, index) => (
                <button
                  type="button"
                  class="relative flex-1 px-4 pb-6 text-center font-logo text-[1.05rem] font-normal uppercase tracking-[0.14em] transition duration-300"
                  x-bind:class={`active === ${index} ? 'text-[#141820]' : 'text-[#8b929e] hover:text-[#141820]'`}
                  x-bind:aria-selected={`active === ${index}`}
                  role="tab"
                  @click={`active = ${index}`}
                  @mouseenter={`active = ${index}`}
                >
                  <span>{service.kicker}</span>
                  <span
                    class="absolute inset-x-0 -bottom-px h-[3px] origin-left bg-gradient-to-r from-brand-300 via-brand-500 to-brand-700 transition-transform duration-500"
                    x-bind:class={`active === ${index} ? 'scale-x-100' : 'scale-x-0'`}
                    aria-hidden="true"
                  ></span>
                </button>
              ))
            }
          </div>
          </div>
        </div>

        <div data-reveal data-reveal-delay="220" class="grid pt-12 bg-white">
          {
            serviceGroups.map((service, index) => (
              <article
                class="col-start-1 row-start-1 overflow-hidden bg-[radial-gradient(circle_at_66%_32%,rgba(255,255,255,0.88),rgba(255,255,255,0.42)_28%,transparent_52%),radial-gradient(circle_at_6%_96%,rgba(214,222,250,0.72),transparent_42%),radial-gradient(circle_at_86%_14%,rgba(98,196,243,0.24),transparent_32%),linear-gradient(135deg,rgba(98,196,243,0.14)_0%,rgba(238,247,251,0.9)_42%,rgba(214,222,250,0.48)_100%)] shadow-[0_22px_70px_rgba(20,24,32,0.08),0_1px_4px_rgba(20,24,32,0.05)]"
                @touchstart.passive="_tx = $event.touches[0].clientX"
                @touchend.passive="let dx = $event.changedTouches[0].clientX - _tx; if (Math.abs(dx) > 50) active = dx < 0 ? Math.min(active + 1, 2) : Math.max(active - 1, 0)"
                x-show={`active === ${index}`}
                x-transition:enter="transition-opacity ease-out duration-700"
                x-transition:enter-start="opacity-0"
                x-transition:enter-end="opacity-100"
                x-transition:leave="transition-opacity ease-in duration-300"
                x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0"
                x-cloak={index !== 0}
                role="tabpanel"
              >
                <div class="grid lg:grid-cols-[2fr_3fr]">
                  <div class="relative min-h-[320px] overflow-hidden sm:min-h-[430px] lg:min-h-[560px]">
                    <Image
                      src={service.image}
                      alt={service.imageAlt}
                      class="absolute inset-0 h-full w-full object-cover"
                      widths={[520, 720, 960]}
                      sizes="(min-width: 1024px) 40vw, 100vw"
                      loading="eager"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#141820]/34 via-[#141820]/4 to-transparent"></div>
                  </div>

                  <div class="flex flex-col justify-center p-7 sm:p-9 lg:p-14 xl:p-16">
                    <p class="mb-3 text-[0.67rem] font-medium uppercase tracking-[0.22em] text-brand-500">{service.kicker}</p>
                    <h3 class="font-display text-[clamp(1.625rem,2.15vw,2.5rem)] font-normal leading-[1.12] text-ink">
                      {service.title}
                    </h3>
                    <p class="mt-6 max-w-[64ch] text-[1.0625rem] leading-[1.75] text-[#5a6070]">{service.copy}</p>

                    <div class="mt-8 grid gap-3 sm:grid-cols-2">
                      {service.items.map((item) => (
                        <div class="flex items-start gap-2.5 text-[0.78rem] font-semibold uppercase tracking-[0.08em] text-[#141820]">
                          <Check class="mt-0.5 size-4 shrink-0 text-brand-500" stroke-width={2.5} aria-hidden="true" />
                          <span>{item}</span>
                        </div>
                      ))}
                    </div>

                    <a
                      href={bookingUrl}
                      class="brand-cut-button mt-9 inline-flex self-center lg:self-start items-center gap-2 px-7 py-3.5 text-[0.875rem] font-medium text-white transition hover:-translate-y-px"
                    >
                      Book This Treatment
