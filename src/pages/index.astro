---
import { Image } from 'astro:assets';
import {
  ArrowRight,
  Check,
  LockKeyhole,
  ShieldCheck,
  Sparkles,
  UsersRound,
} from '@lucide/astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import beforeAfter1 from '../assets/images/before-after-1.jpg';
import beforeAfter2 from '../assets/images/before-after-2.jpg';
import beforeAfter3 from '../assets/images/before-after-3.jpg';
import beforeAfter4 from '../assets/images/before-after-4.jpg';
import beforeAfter5 from '../assets/images/before-after-5.jpg';
import beforeAfter6 from '../assets/images/before-after-6.jpg';
import beforeAfter7 from '../assets/images/before-after-7.jpg';
import beforeAfter8 from '../assets/images/before-after-8.jpg';
import beforeAfter9 from '../assets/images/before-after-9.jpg';
import marbleBackground from '../assets/images/bg.jpg';
import homeHeroImage from '../assets/images/home-hero.png';
import service3Image from '../assets/images/service-3.jpeg';
import serviceImage from '../assets/images/service.png';
import service2Image from '../assets/images/service2.png';
import teamAmanda from '../assets/images/team-amanda.jpg';
import teamCourtney from '../assets/images/team-courtney.jpg';
import teamHarley from '../assets/images/team-harley.jpg';
import teamImage from '../assets/images/team.jpg';
import teamMelissa from '../assets/images/team-melissa.jpg';
import meetingImage from '../assets/images/meeting.jpeg';

const bookingUrl = 'https://www.myaestheticspro.com/';

const trustItems = [
  { icon: ShieldCheck, title: 'Medical expertise', copy: 'Licensed aesthetic providers' },
  { icon: Sparkles, title: 'Natural results', copy: 'Refined, never overdone' },
  { icon: LockKeyhole, title: 'Safety first', copy: 'Personalized treatment plans' },
  { icon: UsersRound, title: 'Trusted by patients', copy: '5 star experience' },
];

const serviceGroups = [
  {
    kicker: 'Glowing Skin',
    title: 'Professional care for clear, refreshed skin.',
    copy:
      'Aesthetic skin treatments support confidence, self-care, and long-term skin health by addressing tone, texture, acne, fine lines, and loss of elasticity.',
    image: serviceImage,
    imageAlt: 'Access Aesthetics treatment room',
    items: ['Morpheus 8 RF Microneedling', 'Rejuvapen Microneedling', 'Laser Hair Removal', 'Chemical Peels & Facials'],
  },
  {
    kicker: 'Restorative Beauty',
    title: 'Subtle rejuvenation with a natural finish.',
    copy:
      'Restorative procedures help soften lines, restore volume, reduce sun damage, and improve tone so every treatment feels personalized and balanced.',
    image: service2Image,
    imageAlt: 'Aesthetic injectable treatment in progress',
    reverse: true,
    items: ['Neurotoxins', 'Dermal Fillers', 'IPL Therapy', 'Bio-Filler & PRP'],
  },
  {
    kicker: 'Balanced Radiance',
    title: 'Full-body aesthetic wellness for lasting confidence.',
    copy:
      'From advanced rejuvenation to hydration and therapeutic therapies, full-body care supports outer radiance and a renewed sense of vitality.',
    image: service3Image,
    imageAlt: 'Calming facial treatment at Access Aesthetics',
    items: ['Vitamin Injections', 'Lash & Brow Services', 'Biostimulators', 'Skin Care'],
  },
];

const team = [
  {
    name: 'Amanda Clementi',
    title: 'Director of Aesthetics & Health and Wellness',
    copy:
      'Amanda’s goal at Access Aesthetics is to empower clients to feel confident and rejuvenated through high-quality, personalized beauty and wellness treatments.',
    image: teamAmanda,
    href: 'https://www.accessofla.com/amanda-clementi',
    cta: 'Meet Amanda',
  },
  {
    name: 'Courtney Muller',
    title: 'MSN, APRN, FNP-C',
    copy:
      'With over 13 years of experience, Courtney brings enthusiasm, compassion, and a warm personality to every client relationship.',
    image: teamCourtney,
    href: 'https://www.accessofla.com/courtney-miller',
    cta: 'Meet Courtney',
  },
  {
    name: 'Harley Lonardo',
    title: 'Advanced Medical Esthetician',
    copy:
      'Harley excels in both medical and beauty aesthetic services, tailoring each treatment to her client’s needs with skill and care.',
    image: teamHarley,
    href: 'https://www.accessofla.com/harley-lonardo',
    cta: 'Meet Harley',
  },
  {
    name: 'Melissa Holley',
    title: 'Medical Esthetician',
    copy:
      'Melissa has spent more than 20 years helping women love their skin and create plans that support their goals.',
    image: teamMelissa,
    href: 'https://www.accessofla.com/melissa-holley',
    cta: 'Meet Melissa',
  },
];

const teamHotspots = [
  { name: 'Melissa Holley', title: 'Medical Esthetician', href: '#', x: '18%', y: '80%' },
  { name: 'Courtney Muller', title: 'MSN, APRN, FNP-C', href: '#', x: '41%', y: '80%' },
  { name: 'Amanda Clementi', title: 'Director of Aesthetics & Health and Wellness', href: '#', x: '60%', y: '80%' },
  { name: 'Harley Lonardo', title: 'Advanced Medical Esthetician', href: '#', x: '81%', y: '80%' },
];

const transformations = [
  { image: beforeAfter1, alt: 'Before and after aesthetic treatment result' },
  { image: beforeAfter2, alt: 'Before and after facial rejuvenation result' },
  { image: beforeAfter3, alt: 'Before and after skin treatment result' },
  { image: beforeAfter4, alt: 'Before and after skin rejuvenation result' },
  { image: beforeAfter5, alt: 'Before and after facial treatment result' },
  { image: beforeAfter6, alt: 'Before and after aesthetic care result' },
  { image: beforeAfter7, alt: 'Before and after complexion treatment result' },
  { image: beforeAfter8, alt: 'Before and after refreshed skin result' },
  { image: beforeAfter9, alt: 'Before and after Access Aesthetics result' },
];

const transformationSlides = Array.from({ length: Math.ceil(transformations.length / 3) }, (_, index) =>
  transformations.slice(index * 3, index * 3 + 3).map((item, itemIndex) => ({
    ...item,
    originalIndex: index * 3 + itemIndex,
  }))
);
---

<BaseLayout
  title="Access Aesthetics | Medical Spa in Slidell, LA"
  description="Access Aesthetics is a Slidell, Louisiana medical spa offering injectables, skin treatments, laser services, facials, and aesthetic wellness care."
>
  <Header />
  <main id="home" class="overflow-hidden bg-[#f9f8f6] text-[#141820]">
    <section class="bg-white pt-20">
      <div class="relative isolate min-h-[calc(100vh-12rem)] overflow-hidden bg-white">
        <div class="absolute inset-y-0 right-0 -z-30 h-full w-full lg:w-[62%]">
          <Image
            src={homeHeroImage}
            alt="Client receiving an injectable aesthetic treatment"
            class="h-full w-full object-cover object-[55%_25%]"
            widths={[720, 960, 1280, 1448]}
            sizes="(min-width: 1024px) 62vw, 100vw"
            priority
          />
        </div>
        <svg
          class="pointer-events-none absolute inset-y-0 right-0 z-0 hidden h-full w-[62%] text-brand-300 [mask-image:linear-gradient(to_right,black_0%,black_52%,transparent_78%)] lg:block"
          viewBox="0 0 800 760"
          preserveAspectRatio="xMidYMid slice"
          aria-hidden="true"
        >
          <circle cx="370" cy="380" r="260" fill="none" stroke="currentColor" stroke-width="1" opacity="0.26" />
          <circle cx="370" cy="380" r="380" fill="none" stroke="currentColor" stroke-width="1" opacity="0.22" />
        </svg>
        <!--bg-linear-to-r from-[#f3e7e9] via-[#e3eeff] to-white-->
        <div class="absolute inset-0 -z-20 bg-gradient-to-r from-[#D6DEFA66] via-white from-[0%] via-white via-[49%] to-white/0 to-[78%]"></div>
        <div class="absolute inset-x-0 bottom-0 -z-20 h-32 bg-gradient-to-t from-white to-transparent"></div>

        <div class="relative z-10 mx-auto flex min-h-[calc(100vh-12rem)] max-w-[calc(1280px+8rem)] items-center px-5 py-16 sm:px-8 lg:px-16 lg:py-22">
          <div class="max-w-[56rem]">
          <p class="hero-text-shadow mb-7 text-[0.67rem] font-semibold uppercase tracking-[0.22em] text-brand-500">
            Medical aesthetics. Personalized for you.
          </p>
          <h1 class="hero-text-shadow font-script text-[clamp(5rem,8vw,8.5rem)] font-normal leading-[0.82] tracking-normal text-[#141820]">
            <!--Redefining<br /> Aesthetic Wellness-->
            Radiance Redefined
          </h1>
          <!--<h1 class="hero-text-shadow font-display text-[clamp(3.5rem,5.15vw,5.8rem)] font-bold leading-[1.04] tracking-[-0.01em] text-[#141820]">-->
          <!--  Subtle work.<br />Noticeable confidence.-->
          <!--</h1>-->
          <!--max-w-[36ch] -->
          <p class="hero-text-shadow mt-6
          text-lg leading-[1.7] text-[#5a6070]">
            <!--With Precision, Innovation & Care-->
            Evidence based treatments. Expert care. Results that look like you, only refreshed.
          </p>
          <div class="mt-11 flex flex-col items-start gap-6 sm:flex-row sm:items-center">
            <a
              href={bookingUrl}
              class="brand-cut-button inline-flex items-center gap-2 px-7 py-3.5 text-[0.9375rem] font-medium text-white transition hover:-translate-y-px"
            >
              Book your consult
            </a>
            <a
              href="#services"
              class="group inline-flex items-center gap-1.5 border-b border-[#e4e0db] pb-0.5 text-[0.9375rem] text-[#141820] transition hover:border-brand-500 hover:text-brand-700"
            >
              Explore treatments
              <ArrowRight class="size-4 transition group-hover:translate-x-1" aria-hidden="true" />
            </a>
          </div>
        </div>
        </div>
      </div>

      <div class="border-t border-brand-100 bg-brand-50">
        <div class="mx-auto grid max-w-[calc(1280px+8rem)] px-5 sm:grid-cols-2 sm:px-8 lg:grid-cols-4 lg:px-16">
          {
            trustItems.map(({ icon: Icon, title, copy }) => (
              <div class="flex items-center gap-4 border-brand-100 py-7 lg:border-r lg:px-8 first:lg:pl-0 last:lg:border-r-0 last:lg:pr-0">
                <Icon class="size-7 shrink-0 text-brand-700" stroke-width={1.75} aria-hidden="true" />
                <div>
                  <p class="mb-0.5 text-[0.9375rem] font-semibold text-[#141820]">{title}</p>
                  <p class="text-[0.8125rem] text-[#5a6070]">{copy}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="about" class="overflow-hidden bg-[#0f1d29]">
      <div class="grid lg:grid-cols-2">
        <div class="relative min-h-[420px] overflow-hidden lg:min-h-[680px]">
          <Image
            src={meetingImage}
            alt="Access Aesthetics team meeting with a new client"
            class="absolute inset-0 h-full w-full object-cover object-top"
            widths={[720, 960, 1280]}
            sizes="(min-width: 1024px) 50vw, 100vw"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-[#0f1d29]/10 via-transparent to-[#0f1d29]/70 lg:bg-gradient-to-l"></div>
        </div>

        <div class="relative flex w-full items-center overflow-hidden px-6 py-16 sm:px-10 lg:px-16 lg:py-32">
          <div class="absolute -right-24 top-20 h-72 w-72 rounded-full bg-brand-500/18 blur-3xl"></div>
          <div class="absolute bottom-0 left-12 h-56 w-56 rounded-full bg-brand-300/10 blur-3xl"></div>
          <div class="relative mx-auto max-w-2xl">
            <p class="mb-4 text-[0.67rem] font-semibold uppercase tracking-[0.22em] text-brand-300">Welcome To Access Aesthetics</p>
            <h2 class="font-display text-[clamp(2.125rem,3.2vw,3.375rem)] font-normal leading-[1.1] tracking-[-0.01em] text-white">
              Where innovation meets beauty.
            </h2>
            <p class="mt-6 text-lg leading-[1.75] text-[#d6e3ea]">
              From Plexr Plasma and Botox to injectable fillers and transformative spa therapies, licensed experts curate minimally invasive experiences that elevate your beauty with thoughtful, personalized service.
            </p>
            <p class="mt-4 text-lg leading-[1.75] text-[#b9cbd5]">
              At Access, appearances are only part of the story. The goal is a renewed sense of self supported by care, comfort, and modern aesthetic technology.
            </p>
            <div class="pt-8">
              <a
                href={bookingUrl}
                class="brand-cut-button inline-flex items-center gap-2 px-7 py-3.5 text-[0.9375rem] font-medium text-white transition hover:-translate-y-px"
              >
                Book your consult
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section
      id="services"
      class="relative overflow-hidden border-t border-[#edebe7] px-5 py-20 sm:px-10 lg:px-20 lg:py-28"
      style={`background-image: url(${marbleBackground.src}); background-size: cover; background-position: center;`}
    >
      <div class="absolute inset-0 bg-white/42"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-white/58 via-white/32 to-[#eef7fb]/38"></div>
      <div class="relative mx-auto max-w-7xl" x-data="{ active: 0 }">
        <div class="mb-12">
          <p class="mb-3.5 text-[0.67rem] font-semibold uppercase tracking-[0.22em] text-brand-500">
            Treatments for skin, structure, and glow.
          </p>
          <h2 class="font-display text-[clamp(2.25rem,3.4vw,3.75rem)] font-normal leading-[1.05] tracking-[-0.01em] text-[#141820]">
            Premier Aesthetic Experience
          </h2>
          <p class="mt-6 text-[1.0625rem] leading-[1.75] text-[#5a6070]">
            Explore each service focus one at a time, then book a consult for a plan shaped around your skin, goals, and comfort.
          </p>
        </div>

        <div class="overflow-x-auto pb-1">
          <div class="relative flex min-w-[680px] border-b border-[#d9e2e6]" role="tablist" aria-label="Service categories">
            {
              serviceGroups.map((service, index) => (
                <button
                  type="button"
                  class="relative flex-1 px-4 pb-6 text-center font-logo text-[1.05rem] font-normal uppercase tracking-[0.14em] transition duration-300"
                  x-bind:class={`active === ${index} ? 'text-[#141820]' : 'text-[#8b929e] hover:text-[#141820]'`}
                  x-bind:aria-selected={`active === ${index}`}
                  role="tab"
                  @click={`active = ${index}`}
                >
                  <span>{service.kicker}</span>
                  <span
                    class="absolute inset-x-0 -bottom-px h-[3px] origin-left bg-gradient-to-r from-brand-300 via-brand-500 to-brand-700 transition-transform duration-500"
                    x-bind:class={`active === ${index} ? 'scale-x-100' : 'scale-x-0'`}
                    aria-hidden="true"
                  ></span>
                </button>
              ))
            }
          </div>
        </div>

        <div class="grid pt-12">
          {
            serviceGroups.map((service, index) => (
              <article
                class="col-start-1 row-start-1 overflow-hidden bg-[radial-gradient(circle_at_66%_32%,rgba(255,255,255,0.88),rgba(255,255,255,0.42)_28%,transparent_52%),radial-gradient(circle_at_6%_96%,rgba(214,222,250,0.72),transparent_42%),radial-gradient(circle_at_86%_14%,rgba(98,196,243,0.24),transparent_32%),linear-gradient(135deg,rgba(98,196,243,0.14)_0%,rgba(238,247,251,0.9)_42%,rgba(214,222,250,0.48)_100%)] shadow-[0_22px_70px_rgba(20,24,32,0.08),0_1px_4px_rgba(20,24,32,0.05)]"
                x-show={`active === ${index}`}
                x-transition:enter="transition-opacity ease-out duration-700"
                x-transition:enter-start="opacity-0"
                x-transition:enter-end="opacity-100"
                x-transition:leave="transition-opacity ease-in duration-300"
                x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0"
                x-cloak={index !== 0}
                role="tabpanel"
              >
                <div class="grid lg:grid-cols-[2fr_3fr]">
                  <div class="relative min-h-[320px] overflow-hidden sm:min-h-[430px] lg:min-h-[560px]">
                    <Image
                      src={service.image}
                      alt={service.imageAlt}
                      class="absolute inset-0 h-full w-full object-cover"
                      widths={[520, 720, 960]}
                      sizes="(min-width: 1024px) 40vw, 100vw"
                      loading="eager"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#141820]/34 via-[#141820]/4 to-transparent"></div>
                  </div>

                  <div class="flex flex-col justify-center p-7 sm:p-9 lg:p-14 xl:p-16">
                    <p class="mb-3 text-[0.67rem] font-semibold uppercase tracking-[0.22em] text-brand-500">{service.kicker}</p>
                    <h3 class="font-display text-[clamp(2rem,3vw,3.3rem)] font-normal leading-[1.08] text-[#141820]">
                      {service.title}
                    </h3>
                    <p class="mt-6 max-w-[64ch] text-[1.0625rem] leading-[1.75] text-[#5a6070]">{service.copy}</p>

                    <div class="mt-8 grid gap-3 sm:grid-cols-2">
                      {service.items.map((item) => (
                        <div class="flex items-start gap-2.5 text-[0.78rem] font-semibold uppercase tracking-[0.08em] text-[#141820]">
                          <Check class="mt-0.5 size-4 shrink-0 text-brand-500" stroke-width={2.5} aria-hidden="true" />
                          <span>{item}</span>
                        </div>
                      ))}
                    </div>

                    <a
                      href={bookingUrl}
                      class="brand-cut-button mt-9 inline-flex self-start items-center gap-2 px-7 py-3.5 text-[0.875rem] font-medium text-white transition hover:-translate-y-px"
                    >
                      Book This Treatment
                      <ArrowRight class="size-3.5" aria-hidden="true" />
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="team"
      class="relative overflow-hidden border-t border-[#1f6f9d]/30 bg-[#3a477b] px-5 py-20 sm:px-10 lg:px-20 lg:py-28"
    >
      <div class="absolute -right-28 top-16 h-80 w-80 rounded-full bg-brand-500/18 blur-3xl"></div>
      <div class="absolute bottom-0 left-10 h-72 w-72 rounded-full bg-brand-300/10 blur-3xl"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-white/5 via-transparent to-[#07121b]/48"></div>
      <div class="relative mx-auto max-w-7xl">
        <div class="mx-auto mb-14 max-w-3xl text-center">
          <p class="mb-4 text-[0.67rem] font-semibold uppercase tracking-[0.22em] text-brand-300">Behind The Glow</p>
          <h2 class="font-display text-[clamp(2.125rem,3.2vw,3.375rem)] font-normal leading-[1.1] tracking-[-0.01em] text-white">
            Meet Our Team
          </h2>
          <p class="mt-5 text-[1.0625rem] leading-[1.75] text-[#d6e3ea]">
            At Access Aesthetics, our team brings together clinical expertise and a passion for personalized care to help each client look and feel their absolute best. With a commitment to precision, safety, and genuine care, our team is here to guide you on your journey to radiance and self-confidence.
          </p>
        </div>

        <div class="relative mb-10 overflow-visible">
          <div class="overflow-hidden rounded-2xl shadow-[0_32px_95px_rgba(5,17,28,0.34),0_3px_10px_rgba(5,17,28,0.16)]">
            <Image
              src={teamImage}
              alt="Access Aesthetics clinical team"
              class="h-[320px] w-full object-cover object-top sm:h-[420px] lg:h-[500px]"
              widths={[720, 960, 1280, 1600]}
              sizes="(min-width: 1024px) 80vw, 100vw"
            />
          </div>
          <div class="pointer-events-none absolute inset-0 z-10 hidden lg:block">
            {
              teamHotspots.map((hotspot) => (
                <div
                  class="group pointer-events-auto absolute"
                  style={`left: ${hotspot.x}; top: ${hotspot.y};`}
                >
                  <a
                    href={hotspot.href}
                    class="relative flex size-7 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-white/92 shadow-[0_14px_35px_rgba(5,17,28,0.25)] ring-2 ring-brand-300/70 transition hover:scale-110 focus:outline-none focus:ring-4 focus:ring-brand-300/70"
                    aria-label={`Meet ${hotspot.name}`}
                  >
                    <span class="absolute size-7 animate-ping rounded-full bg-brand-300/35"></span>
                    <span class="relative size-2.5 rounded-full bg-brand-700"></span>
                  </a>
                  <div class="pointer-events-auto absolute left-1/2 top-7 w-64 -translate-x-1/2 translate-y-2 pt-5 opacity-0 transition duration-300 group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:translate-y-0 group-focus-within:opacity-100">
                    <a
                      href={hotspot.href}
                      class="block bg-white/96 p-4 text-center shadow-[0_18px_50px_rgba(5,17,28,0.22),0_1px_4px_rgba(5,17,28,0.12)] backdrop-blur transition hover:bg-white focus:outline-none focus:ring-4 focus:ring-brand-300/50"
                    >
                      <p class="font-display text-2xl leading-none text-[#141820]">{hotspot.name}</p>
                      <p class="mt-2 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-brand-600">{hotspot.title}</p>
                      <p class="mt-3 text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-brand-700 underline decoration-brand-300 decoration-2 underline-offset-4">Learn More</p>
                    </a>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!--<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">-->
        <!--  {-->
        <!--    team.map((member) => (-->
        <!--      <article class="flex flex-col overflow-hidden bg-white shadow-[0_28px_80px_rgba(5,17,28,0.28),0_2px_8px_rgba(5,17,28,0.14)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_34px_95px_rgba(5,17,28,0.34),0_3px_10px_rgba(5,17,28,0.16)]">-->
        <!--        <div class="overflow-hidden">-->
        <!--          <Image-->
        <!--            src={member.image}-->
        <!--            alt={member.name}-->
        <!--            class="aspect-[4/5] w-full object-cover transition duration-500 hover:scale-105"-->
        <!--            widths={[360, 520, 720]}-->
        <!--            sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"-->
        <!--          />-->
        <!--        </div>-->
        <!--        <div class="flex flex-1 flex-col items-center p-6 text-center">-->
        <!--          <h3 class="font-display text-[1.65rem] font-normal leading-[1.1] text-[#141820]">{member.name}</h3>-->
        <!--          <p class="mt-2 text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-brand-600">{member.title}</p>-->
        <!--          <p class="mt-4 flex-1 text-[0.95rem] leading-[1.65] text-[#5a6070]">{member.copy}</p>-->
        <!--          <a-->
        <!--            href={member.href}-->
        <!--            class="mt-6 inline-flex items-center gap-1.5 text-[0.78rem] font-semibold uppercase tracking-[0.12em] text-brand-700 underline decoration-brand-300 decoration-2 underline-offset-5 transition hover:text-brand-500"-->
        <!--          >-->
        <!--            {member.cta}-->
        <!--            <ArrowRight class="size-3.5" aria-hidden="true" />-->
        <!--          </a>-->
        <!--        </div>-->
        <!--      </article>-->
        <!--    ))-->
        <!--  }-->
        <!--</div>-->
      </div>
    </section>

    <section
      id="transformations"
      class="relative overflow-hidden border-t border-[#edebe7] px-5 py-20 sm:px-10 lg:px-20 lg:py-28"
    >
      <div
        class="absolute inset-0 scale-x-[-1] scale-y-[-1] bg-cover bg-center"
        style={`background-image: url(${marbleBackground.src});`}
      ></div>
      <div class="absolute inset-0 bg-white/34"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-[#eef7fb]/28 via-white/22 to-white/44"></div>
      <div
        class="relative mx-auto max-w-7xl"
        x-data={`{
          active: 0,
          lightbox: null,
          paused: false,
          total: ${transformationSlides.length},
          next() { this.active = (this.active + 1) % this.total },
          prev() { this.active = (this.active - 1 + this.total) % this.total }
        }`}
        x-init="setInterval(() => { if (!paused && lightbox === null) next() }, 4200)"
        @keydown.window.escape="lightbox = null"
      >
        <div class="mb-12 flex flex-col gap-8 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-[0.67rem] font-semibold uppercase tracking-[0.22em] text-brand-500">Before and After</p>
            <h2 class="mt-3.5 max-w-[28ch] font-display text-[clamp(2.125rem,3.2vw,3.375rem)] font-normal leading-[1.1] tracking-[-0.01em] text-[#141820]">
              Visible change, guided by thoughtful treatment plans.
            </h2>
          </div>
          <a
            href={bookingUrl}
            class="brand-cut-button inline-flex shrink-0 items-center gap-2 self-start whitespace-nowrap px-7 py-3.5 text-[0.9375rem] font-medium text-white transition hover:-translate-y-px sm:self-auto"
          >
            Start Yours
            <ArrowRight class="size-3.5" aria-hidden="true" />
          </a>
        </div>

        <div
          class="overflow-hidden"
          @mouseenter="paused = true"
          @mouseleave="paused = false"
        >
          <div
            class="flex transition-transform duration-[1200ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
            x-bind:style="`transform: translateX(-${active * 100}%);`"
          >
          {
            transformationSlides.map((slide) => (
              <div class="grid min-w-full gap-5 md:grid-cols-3">
                {slide.map((item) => (
                  <figure class="bg-white/82 p-3 shadow-[0_22px_70px_rgba(20,24,32,0.08),0_1px_4px_rgba(20,24,32,0.05)] backdrop-blur">
                    <button
                      type="button"
                      class="group block w-full overflow-hidden"
                      aria-label={`Open transformation ${item.originalIndex + 1}`}
                      @click={`lightbox = ${item.originalIndex}`}
                    >
                      <Image
                        src={item.image}
                        alt={item.alt}
                        class="aspect-square w-full object-cover transition duration-700 group-hover:scale-[1.04]"
                        widths={[420, 640, 960]}
                        sizes="(min-width: 768px) 33vw, 100vw"
                      />
                    </button>
                    <figcaption class="flex items-center justify-between gap-4 px-1.5 pb-1 pt-3.5 text-xs font-semibold uppercase tracking-[0.16em] text-[#8b929e]">
                      <span>Access Transformation</span>
                      <span>{String(item.originalIndex + 1).padStart(2, '0')} / {String(transformations.length).padStart(2, '0')}</span>
                    </figcaption>
                  </figure>
                ))}
              </div>
            ))
          }
          </div>
        </div>

        <div class="mt-7 flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-center gap-2">
            {
              transformationSlides.map((_, index) => (
                <button
                  type="button"
                  class="h-2.5 rounded-full transition-all duration-500"
                  x-bind:class={`active === ${index} ? 'w-10 bg-brand-600' : 'w-2.5 bg-[#9aa8b1]/55 hover:bg-brand-400'`}
                  aria-label={`Show transformation group ${index + 1}`}
                  @click={`active = ${index}`}
                ></button>
              ))
            }
          </div>

          <div class="flex items-center gap-3">
            <button
              type="button"
              class="inline-flex size-11 items-center justify-center bg-white/82 text-brand-700 shadow-[0_14px_35px_rgba(20,24,32,0.1)] transition hover:bg-white hover:text-brand-500"
              aria-label="Previous transformation"
              @click="prev()"
            >
              <ArrowRight class="size-4 rotate-180" aria-hidden="true" />
            </button>
            <button
              type="button"
              class="inline-flex size-11 items-center justify-center bg-white/82 text-brand-700 shadow-[0_14px_35px_rgba(20,24,32,0.1)] transition hover:bg-white hover:text-brand-500"
              aria-label="Next transformation"
              @click="next()"
            >
              <ArrowRight class="size-4" aria-hidden="true" />
            </button>
          </div>
        </div>

        <div
          class="fixed inset-0 z-[100] flex items-center justify-center bg-[#07121b]/88 p-4 backdrop-blur-sm"
          x-show="lightbox !== null"
          x-cloak
          x-transition.opacity.duration.300ms
          @click.self="lightbox = null"
        >
          {
            transformations.map((item, index) => (
              <div
                class="max-h-[90vh] w-full max-w-5xl"
                x-show={`lightbox === ${index}`}
                x-transition.opacity.duration.300ms
              >
                <div class="relative bg-white p-3 shadow-[0_32px_100px_rgba(0,0,0,0.42)]">
                  <button
                    type="button"
                    class="absolute right-4 top-4 z-10 bg-white/92 px-4 py-2 font-logo text-sm uppercase tracking-[0.14em] text-[#141820] shadow-[0_12px_30px_rgba(20,24,32,0.16)] transition hover:text-brand-700"
                    @click="lightbox = null"
                  >
                    Close
                  </button>
                  <Image
                    src={item.image}
                    alt={item.alt}
                    class="max-h-[82vh] w-full object-contain"
                    widths={[720, 960, 1280, 1440]}
                    sizes="90vw"
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
